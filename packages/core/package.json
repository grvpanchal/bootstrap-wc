{
  "name": "@bootstrap-wc/core",
  "version": "0.2.0",
  "description": "Core base class, controllers, and styles for Bootstrap Web Components.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grvpanchal/bootstrap-wc.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scss/*": "./src/scss/*"
  },
  "files": [
    "dist",
    "src/scss"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node scripts/generate-bootstrap-css.mjs && tsc -b && cp -r src/scss dist/scss",
    "prepublishOnly": "node scripts/generate-bootstrap-css.mjs",
    "build:watch": "tsc -b --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.0",
    "focus-trap": "^7.5.4"
  },
  "devDependencies": {
    "bootstrap": "^5.3.3",
    "lit": "^3.1.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "bootstrap",
    "web-components",
    "lit",
    "custom-elements"
  ]
}
