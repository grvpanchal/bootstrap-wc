{
  "name": "@bootstrap-wc/plugin-morris",
  "version": "0.1.0",
  "description": "Morris.js charts wrapper.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./define": {
      "types": "./dist/define.d.ts",
      "import": "./dist/define.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "lit": "^3.2.1"
  },
  "peerDependencies": {
    "@bootstrap-wc/components": "^0.5.0",
    "morris.js": "^0.5.1"
  },
  "peerDependenciesMeta": {
    "morris.js": { "optional": true }
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grvpanchal/bootstrap-wc.git",
    "directory": "packages/plugin-morris"
  },
  "keywords": ["bootstrap", "web-components", "lit", "plugin", "morris"]
}
