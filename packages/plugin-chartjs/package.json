{
  "name": "@bootstrap-wc/plugin-chartjs",
  "version": "2.0.0",
  "description": "Chart.js 4 wrapper.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./define": {
      "types": "./dist/define.d.ts",
      "import": "./dist/define.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "lit": "^3.2.1"
  },
  "peerDependencies": {
    "@bootstrap-wc/components": "^0.7.0",
    "chart.js": "^4.4.4"
  },
  "peerDependenciesMeta": {
    "chart.js": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grvpanchal/bootstrap-wc.git",
    "directory": "packages/plugin-chartjs"
  },
  "keywords": [
    "bootstrap",
    "web-components",
    "lit",
    "plugin",
    "chartjs"
  ]
}
