{
  "name": "@bootstrap-wc/cli",
  "version": "0.0.0",
  "description": "CLI for adding Bootstrap Web Components to your project (shadcn-style).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grvpanchal/bootstrap-wc.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "bwc": "./bin/bwc.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "kleur": "^4.1.5",
    "ora": "^8.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "bootstrap",
    "web-components",
    "cli",
    "shadcn"
  ]
}
