{
  "name": "@bootstrap-wc/plugin-dropzone",
  "version": "1.1.0",
  "description": "Dropzone 6 file upload wrapper.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./define": {
      "types": "./dist/define.d.ts",
      "import": "./dist/define.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "lit": "^3.2.1"
  },
  "peerDependencies": {
    "@bootstrap-wc/components": "^0.6.0",
    "dropzone": "^6.0.0-beta.2"
  },
  "peerDependenciesMeta": {
    "dropzone": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grvpanchal/bootstrap-wc.git",
    "directory": "packages/plugin-dropzone"
  },
  "keywords": [
    "bootstrap",
    "web-components",
    "lit",
    "plugin",
    "dropzone"
  ]
}
