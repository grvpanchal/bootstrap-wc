{
  "name": "@bootstrap-wc/plugin-flot",
  "version": "2.0.0",
  "description": "Flot charting library wrapper (jQuery dependent).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./define": {
      "types": "./dist/define.d.ts",
      "import": "./dist/define.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "lit": "^3.2.1"
  },
  "peerDependencies": {
    "@bootstrap-wc/components": "^0.7.0",
    "jquery": "^3.7.1"
  },
  "peerDependenciesMeta": {
    "jquery": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grvpanchal/bootstrap-wc.git",
    "directory": "packages/plugin-flot"
  },
  "keywords": [
    "bootstrap",
    "web-components",
    "lit",
    "plugin",
    "flot"
  ]
}
