{
  "name": "@bootstrap-wc/react",
  "version": "0.1.0",
  "description": "React wrappers for Bootstrap Web Components (preview).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grvpanchal/bootstrap-wc.git",
    "directory": "packages/react"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b",
    "generate": "node scripts/generate.mjs",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@bootstrap-wc/components": "*",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@lit/react": "^1.0.0"
  },
  "devDependencies": {
    "@bootstrap-wc/components": "*",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "bootstrap",
    "web-components",
    "react"
  ]
}
