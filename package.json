{
  "name": "bootstrap-web-components",
  "version": "0.1.0",
  "private": true,
  "description": "Bootstrap as Web Components. Own your components. Ship anywhere.",
  "license": "MIT",
  "homepage": "https://bootstrap-wc.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/grvpanchal/bootstrap-web-components.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "registry"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:core": "npm run build --workspace @bootstrap-wc/core",
    "build:components": "npm run build --workspace @bootstrap-wc/components",
    "build:cli": "npm run build --workspace @bootstrap-wc/cli",
    "build:react": "npm run build --workspace @bootstrap-wc/react",
    "build:registry": "npm run build --workspace @bootstrap-wc/registry",
    "build:docs": "npm run build --workspace @bootstrap-wc/docs",
    "dev:docs": "npm run dev --workspace @bootstrap-wc/docs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc -b",
    "lint": "eslint . --ext .ts,.js",
    "format": "prettier --write \"**/*.{ts,js,json,md,mdx,scss,astro}\"",
    "clean": "rm -rf packages/*/dist apps/*/dist apps/*/.astro registry/dist **/*.tsbuildinfo",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "@astrojs/sitemap": "3.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
