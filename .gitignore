# Dependencies
node_modules/
.pnp/
.pnp.js

# Build outputs
dist/
build/
.astro/
storybook-static/
*.tsbuildinfo

# Caches
.cache/
.turbo/
.eslintcache
.parcel-cache/

# Registry output (generated)
apps/docs/public/r/*.json
!apps/docs/public/r/.gitkeep

# Audit artifacts from scripts/compare-bootstrap.mjs and
# scripts/check-docs-readability.mjs. Ignore the directory contents,
# but keep the readability-memory.json snapshot tracked so the
# readability auditor can do incremental runs across sessions.
# (Negation only works when the parent directory itself is not ignored,
# which is why we ignore .audit/* instead of .audit/.)
.audit/*
!.audit/readability-memory.json

# Claude Code local state (agent worktrees, etc.)
.claude/worktrees/

# Env + secrets
.env
.env.local
.env.*.local
*.pem

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test output
coverage/
.nyc_output/

# Temp
tmp/
temp/
