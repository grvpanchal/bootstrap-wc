---
// Custom docs layout — built with @bootstrap-wc/components.
// No Starlight; everything chrome (navbar, mobile sidebar, theme toggle,
// in-page nav) is a bs-* element from this library.
import '../styles/bootstrap.css';
import '../styles/custom.css';
import SidebarNav from '../components/SidebarNav.astro';

export interface Props {
  title: string;
  description?: string;
  /** Slug of the active page within the sidebar tree (e.g. `components/button`). */
  activeSlug?: string;
}

const { title, description, activeSlug } = Astro.props;
const fullTitle = title === 'Bootstrap Web Components'
  ? title
  : `${title} | Bootstrap Web Components`;
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <script is:inline>
      // Restore saved theme before paint to avoid FOUC. Defaults to system
      // preference, falls back to light.
      (function () {
        try {
          var saved = localStorage.getItem('bwc-theme');
          var theme =
            saved ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-bs-theme', theme);
        } catch (e) {}
      })();
    </script>
    <script>
      // Register every bs-* custom element on first page load.
      import '@bootstrap-wc/components';
    </script>
    <!--
      Bootstrap's bundle JS handles native-markup togglers across the docs
      site: `data-bs-toggle="collapse"` / `"offcanvas"` / `"dropdown"` etc.
      The bs-* components own their own behavior, but live `<Example>`
      blocks demoing native patterns (the navbar collapse toggler, the
      legacy modal trigger button, etc.) still need the stock plugin.
    -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </head>
  <body class="d-flex flex-column min-vh-100">
    <!--
      `expand="always"` keeps the toolbar inline at every viewport — the
      mobile sidebar uses its own `<bs-button>` trigger (below) to open
      the offcanvas, so we don't want a second collapse-style toggler.
      `container="none"` skips bs-navbar's default `.container-fluid`
      wrapper since we already provide our own toolbar `<div>` with the
      utility padding the layout wants.
    -->
    <bs-navbar
      expand="always"
      placement="sticky-top"
      background="body"
      container="none"
      class="border-bottom"
      aria-label="Main"
    >
      <div class="d-flex align-items-center gap-2 w-100 px-3 px-lg-4">
        <bs-button
          variant="none"
          class="btn btn-outline-secondary border-0 d-lg-none"
          aria-label="Open navigation"
          onclick="document.querySelector('#mobile-sidebar').open = true"
        >
          <i class="bi bi-list fs-4"></i>
        </bs-button>
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
          <span class="badge bg-primary fs-6">B</span>
          <span class="fw-semibold d-none d-sm-inline">Bootstrap Web Components</span>
          <span class="fw-semibold d-sm-none">BWC</span>
        </a>
        <div class="ms-auto d-flex align-items-center gap-2">
          <bs-button
            id="search-trigger"
            variant="none"
            class="btn btn-outline-secondary border-0 d-inline-flex align-items-center gap-2"
            aria-label="Search docs"
            onclick="document.getElementById('docs-search').show()"
          >
            <i class="bi bi-search fs-5"></i>
            <kbd class="d-none d-md-inline small">/</kbd>
          </bs-button>
          <a
            class="btn btn-outline-secondary border-0"
            href="https://github.com/grvpanchal/bootstrap-wc"
            aria-label="GitHub"
            target="_blank"
            rel="noopener"
          >
            <i class="bi bi-github fs-5"></i>
          </a>
          <bs-button
            id="theme-toggle"
            variant="none"
            class="btn btn-outline-secondary border-0"
            aria-label="Toggle theme"
            onclick="(function(){var r=document.documentElement;var n=r.getAttribute('data-bs-theme')==='dark'?'light':'dark';r.setAttribute('data-bs-theme',n);try{localStorage.setItem('bwc-theme',n)}catch(e){}})()"
          >
            <i class="bi bi-circle-half fs-5"></i>
          </bs-button>
        </div>
      </div>
    </bs-navbar>

    <div class="container-fluid flex-grow-1">
      <div class="row flex-grow-1">
        <!--
          Desktop sidebar. The inner `position-sticky` div is capped to
          `100vh - <navbar-height + top-offset>` and set to
          `overflow-y: auto` so long nav lists (Getting started + Resources
          + ~30 components + ~24 plugins) can scroll independently of the
          article. Without the cap the sticky container just spills off
          the bottom of the viewport and the bottom entries become
          unreachable while the article is scrolled to the top.
        -->
        <aside class="col-lg-3 col-xl-2 d-none d-lg-block border-end pt-4">
          <div class="docs-sidebar-sticky position-sticky overflow-y-auto">
            <SidebarNav activeSlug={activeSlug} />
          </div>
        </aside>

        <!-- Mobile sidebar (offcanvas) -->
        <bs-offcanvas
          id="mobile-sidebar"
          placement="start"
          heading="Bootstrap Web Components"
          class="d-lg-none"
        >
          <SidebarNav activeSlug={activeSlug} />
        </bs-offcanvas>

        <!-- Main content -->
        <main class="col-12 col-lg-9 col-xl-10 px-3 px-lg-5 py-4">
          <article class="docs-content mx-auto" style="max-width: 56rem">
            <slot />
          </article>
        </main>
      </div>
    </div>

    <!--
      Site-wide search. Pagefind (https://pagefind.app) builds a static
      index over the rendered HTML in a post-build step (`npm run build`
      runs `pagefind --site dist` after `astro build`). The UI is a
      <bs-modal> driven by inline JS below — search-as-you-type into a
      <bs-input>, results render as a <bs-list-group as="div"> of links.
    -->
    <bs-modal id="docs-search" heading="Search docs" scrollable>
      <div class="d-flex flex-column gap-3">
        <bs-input
          id="search-input"
          type="search"
          placeholder="Search components, examples, getting started…"
          autocomplete="off"
          autofocus
        ></bs-input>
        <div id="search-status" class="text-body-secondary small" hidden>
          Loading search index…
        </div>
        <bs-list-group as="div" id="search-results" class="overflow-auto" style="max-height: 60vh">
        </bs-list-group>
        <div id="search-empty" class="text-body-secondary text-center py-3" hidden>
          No matches.
        </div>
      </div>
    </bs-modal>

    <script>
      // Drive the docs search modal off of Pagefind's static index.
      // Imports `pagefind` lazily on first open so the rest of the
      // page doesn't carry the cost.
      (function () {
        const modal = document.getElementById('docs-search');
        const input = document.getElementById('search-input');
        const results = document.getElementById('search-results');
        const empty = document.getElementById('search-empty');
        const status = document.getElementById('search-status');
        if (!modal || !input || !results) return;

        // Cmd/Ctrl-K and bare `/` open the modal.
        document.addEventListener('keydown', (ev) => {
          const target = ev.target;
          const inField =
            target instanceof HTMLElement &&
            (target.matches('input, textarea, [contenteditable]') ||
              target.shadowRoot?.activeElement?.matches('input, textarea'));
          if ((ev.key === 'k' && (ev.metaKey || ev.ctrlKey)) || (ev.key === '/' && !inField)) {
            ev.preventDefault();
            modal.show();
          }
        });

        let pagefind = null;
        let lastQuery = '';
        async function loadIndex() {
          if (pagefind) return pagefind;
          status.hidden = false;
          try {
            // /* @vite-ignore */ keeps Vite from trying to resolve the path
            // at build time — the file is generated by pagefind post-build.
            pagefind = await import(/* @vite-ignore */ '/pagefind/pagefind.js');
            await pagefind.init?.();
            await pagefind.options?.({ baseUrl: '/' });
          } catch (e) {
            status.textContent =
              'Search index unavailable. Run `npm run build` to generate it.';
            return null;
          } finally {
            status.hidden = true;
          }
          return pagefind;
        }

        modal.addEventListener('bs-show', () => {
          loadIndex();
          // Focus the inner native input after the modal renders.
          requestAnimationFrame(() => {
            const nativeInput = input.shadowRoot?.querySelector('input') ?? input.querySelector('input');
            nativeInput?.focus();
            nativeInput?.select();
          });
        });

        async function runSearch(query) {
          lastQuery = query;
          if (!query.trim()) {
            results.innerHTML = '';
            empty.hidden = true;
            return;
          }
          const pf = await loadIndex();
          if (!pf) return;
          const search = await pf.search(query);
          // Guard against out-of-order responses.
          if (query !== lastQuery) return;
          const hits = await Promise.all(search.results.slice(0, 10).map((r) => r.data()));
          if (query !== lastQuery) return;
          if (!hits.length) {
            results.innerHTML = '';
            empty.hidden = false;
            return;
          }
          empty.hidden = true;
          results.innerHTML = hits
            .map((h) => {
              const title = h.meta?.title || h.url;
              const excerpt = (h.excerpt || '').replace(/<[^>]+>/g, '');
              return `<bs-list-group-item href="${h.url}" action>
                <div class="fw-semibold">${escapeHtml(title)}</div>
                <div class="small text-body-secondary">${escapeHtml(excerpt)}</div>
              </bs-list-group-item>`;
            })
            .join('');
        }

        function escapeHtml(s) {
          return String(s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');
        }

        // Debounce typing.
        let timer = null;
        input.addEventListener('input', (ev) => {
          const value = ev.target.value;
          clearTimeout(timer);
          timer = window.setTimeout(() => runSearch(value), 80);
        });
      })();
    </script>

    <footer class="border-top py-3 mt-auto text-body-secondary small">
      <div class="container-fluid text-center">
        Built with <a href="/components/" class="link-primary">@bootstrap-wc/components</a>.
      </div>
    </footer>
  </body>
</html>
