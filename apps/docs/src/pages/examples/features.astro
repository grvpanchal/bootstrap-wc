---
// Standalone port of https://getbootstrap.com/docs/5.3/examples/features/
// to bootstrap-wc components. Comparator pair lives at
// apps/docs/src/pages/compare/example-features/.

const customCards = [
  { title: 'Short title, long jacket', meta: 'Earth', dur: '3d', textShadow: 'text-shadow-1', extraText: 'text-white' },
  { title: 'Much longer title that wraps to multiple lines', meta: 'Pakistan', dur: '4d', textShadow: 'text-shadow-1', extraText: 'text-white' },
  { title: 'Another longer title belongs here', meta: 'California', dur: '5d', textShadow: 'text-shadow-1', extraText: '' },
];
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Features example · bootstrap-wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .b-example-divider {
        width: 100%;
        height: 3rem;
        background-color: rgba(0, 0, 0, 0.1);
        border: solid rgba(0, 0, 0, 0.15);
        border-width: 1px 0;
        box-shadow:
          inset 0 0.5em 1.5em rgba(0, 0, 0, 0.1),
          inset 0 0.125em 0.5em rgba(0, 0, 0, 0.15);
      }
      .feature-icon {
        width: 4rem;
        height: 4rem;
        border-radius: 0.75rem;
      }
      .feature-icon-small {
        width: 3rem;
        height: 3rem;
      }
      .icon-square {
        width: 3rem;
        height: 3rem;
        border-radius: 0.75rem;
      }
      .text-shadow-1 {
        text-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.25);
      }
      .card-cover {
        background-repeat: no-repeat;
        background-position: center center;
        background-size: cover;
      }
      .card-cover-1 {
        background-image: linear-gradient(135deg, #4b6cb7 0%, #182848 100%);
      }
      .card-cover-2 {
        background-image: linear-gradient(135deg, #134e5e 0%, #71b280 100%);
      }
      .card-cover-3 {
        background-image: linear-gradient(135deg, #f7971e 0%, #ffd200 100%);
      }
    </style>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body>
    <main>
      <div class="container px-4 py-5">
        <h2 class="pb-2 border-bottom">Columns with icons</h2>
        <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
          <div class="feature col">
            <div class="feature-icon d-inline-flex align-items-center justify-content-center text-bg-primary bg-gradient fs-2 mb-3"></div>
            <h3 class="fs-2 text-body-emphasis">Featured title</h3>
            <p>Paragraph of text beneath the heading to explain the heading. We'll add onto it with another sentence and probably just keep going until we run out of words.</p>
            <a href="#" class="icon-link">Call to action</a>
          </div>
          <div class="feature col">
            <div class="feature-icon d-inline-flex align-items-center justify-content-center text-bg-primary bg-gradient fs-2 mb-3"></div>
            <h3 class="fs-2 text-body-emphasis">Featured title</h3>
            <p>Paragraph of text beneath the heading to explain the heading. We'll add onto it with another sentence and probably just keep going until we run out of words.</p>
            <a href="#" class="icon-link">Call to action</a>
          </div>
          <div class="feature col">
            <div class="feature-icon d-inline-flex align-items-center justify-content-center text-bg-primary bg-gradient fs-2 mb-3"></div>
            <h3 class="fs-2 text-body-emphasis">Featured title</h3>
            <p>Paragraph of text beneath the heading to explain the heading. We'll add onto it with another sentence and probably just keep going until we run out of words.</p>
            <a href="#" class="icon-link">Call to action</a>
          </div>
        </div>
      </div>

      <div class="b-example-divider"></div>

      <div class="container px-4 py-5">
        <h2 class="pb-2 border-bottom">Hanging icons</h2>
        <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
          <div class="col d-flex align-items-start">
            <div class="icon-square text-body-emphasis bg-body-secondary d-inline-flex align-items-center justify-content-center fs-4 flex-shrink-0 me-3"></div>
            <div>
              <h3 class="fs-2 text-body-emphasis">Featured title</h3>
              <p>Paragraph of text beneath the heading to explain the heading. We'll add onto it with another sentence and probably just keep going until we run out of words.</p>
              <bs-button variant="primary" href="#">Primary button</bs-button>
            </div>
          </div>
          <div class="col d-flex align-items-start">
            <div class="icon-square text-body-emphasis bg-body-secondary d-inline-flex align-items-center justify-content-center fs-4 flex-shrink-0 me-3"></div>
            <div>
              <h3 class="fs-2 text-body-emphasis">Featured title</h3>
              <p>Paragraph of text beneath the heading to explain the heading. We'll add onto it with another sentence and probably just keep going until we run out of words.</p>
              <bs-button variant="primary" href="#">Primary button</bs-button>
            </div>
          </div>
          <div class="col d-flex align-items-start">
            <div class="icon-square text-body-emphasis bg-body-secondary d-inline-flex align-items-center justify-content-center fs-4 flex-shrink-0 me-3"></div>
            <div>
              <h3 class="fs-2 text-body-emphasis">Featured title</h3>
              <p>Paragraph of text beneath the heading to explain the heading. We'll add onto it with another sentence and probably just keep going until we run out of words.</p>
              <bs-button variant="primary" href="#">Primary button</bs-button>
            </div>
          </div>
        </div>
      </div>

      <div class="b-example-divider"></div>

      <div class="container px-4 py-5">
        <h2 class="pb-2 border-bottom">Custom cards</h2>
        <div class="row row-cols-1 row-cols-lg-3 align-items-stretch g-4 py-5">
          {customCards.map((c, i) => (
            <div class="col">
              <div class={`card card-cover h-100 overflow-hidden text-bg-dark rounded-4 shadow-lg card-cover-${i + 1}`}>
                <div class={`d-flex flex-column h-100 p-5 pb-3 ${c.extraText} ${c.textShadow}`}>
                  <h3 class="pt-5 mt-5 mb-4 display-6 lh-1 fw-bold">{c.title}</h3>
                  <ul class="d-flex list-unstyled mt-auto">
                    <li class="me-auto">
                      <span class="d-inline-block rounded-circle border border-white" style="width: 32px; height: 32px; background: #6c757d;"></span>
                    </li>
                    <li class="d-flex align-items-center me-3"><small>{c.meta}</small></li>
                    <li class="d-flex align-items-center"><small>{c.dur}</small></li>
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="b-example-divider"></div>

      <div class="container px-4 py-5">
        <h2 class="pb-2 border-bottom">Icon grid</h2>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 py-5">
          {[1, 2, 3, 4, 5, 6, 7, 8].map((n) => (
            <div class="col d-flex align-items-start">
              <div class="bi text-body-secondary flex-shrink-0 me-3 bg-body-secondary rounded-circle" style="width: 1.75em; height: 1.75em;"></div>
              <div>
                <h3 class="fw-bold mb-0 fs-4 text-body-emphasis">Featured title</h3>
                <p>Paragraph of text beneath the heading to explain the heading.</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="b-example-divider"></div>

      <div class="container px-4 py-5">
        <h2 class="pb-2 border-bottom">Features with title</h2>
        <div class="row row-cols-1 row-cols-md-2 align-items-md-center g-5 py-5">
          <div class="col d-flex flex-column align-items-start gap-2">
            <h2 class="fw-bold text-body-emphasis">Left-aligned title explaining these awesome features</h2>
            <p class="text-body-secondary">Paragraph of text beneath the heading to explain the heading. We'll add onto it with another sentence and probably just keep going until we run out of words.</p>
            <bs-button variant="primary" size="lg" href="#">Primary button</bs-button>
          </div>
          <div class="col">
            <div class="row row-cols-1 row-cols-sm-2 g-4">
              <div class="col d-flex flex-column gap-2">
                <div class="feature-icon-small d-inline-flex align-items-center justify-content-center text-bg-primary bg-gradient fs-4 rounded-3"></div>
                <h4 class="fw-semibold mb-0 text-body-emphasis">Featured title</h4>
                <p class="text-body-secondary">Paragraph of text beneath the heading to explain the heading.</p>
              </div>
              <div class="col d-flex flex-column gap-2">
                <div class="feature-icon-small d-inline-flex align-items-center justify-content-center text-bg-primary bg-gradient fs-4 rounded-3"></div>
                <h4 class="fw-semibold mb-0 text-body-emphasis">Featured title</h4>
                <p class="text-body-secondary">Paragraph of text beneath the heading to explain the heading.</p>
              </div>
              <div class="col d-flex flex-column gap-2">
                <div class="feature-icon-small d-inline-flex align-items-center justify-content-center text-bg-primary bg-gradient fs-4 rounded-3"></div>
                <h4 class="fw-semibold mb-0 text-body-emphasis">Featured title</h4>
                <p class="text-body-secondary">Paragraph of text beneath the heading to explain the heading.</p>
              </div>
              <div class="col d-flex flex-column gap-2">
                <div class="feature-icon-small d-inline-flex align-items-center justify-content-center text-bg-primary bg-gradient fs-4 rounded-3"></div>
                <h4 class="fw-semibold mb-0 text-body-emphasis">Featured title</h4>
                <p class="text-body-secondary">Paragraph of text beneath the heading to explain the heading.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
