---
// Standalone port of https://getbootstrap.com/docs/5.3/examples/sticky-footer-navbar/
// to bootstrap-wc components. Comparator pair lives at
// apps/docs/src/pages/compare/example-sticky-footer-navbar/.

---

<!doctype html>
<html lang="en" class="h-100" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sticky footer navbar example · bootstrap-wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      main > .container {
        padding: 60px 15px 0;
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body class="d-flex flex-column h-100">
    <header>
      <bs-navbar expand="md" theme="dark" background="dark" placement="fixed-top" container="fluid">
        <a class="navbar-brand" href="#">Fixed navbar</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarCollapse">
          <bs-nav class="me-auto mb-2 mb-md-0">
            <bs-nav-item href="#" active>Home</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
            <bs-nav-item disabled>Disabled</bs-nav-item>
          </bs-nav>
          <form class="d-flex" role="search">
            <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
            <bs-button variant="success" button-style="outline" type="submit">Search</bs-button>
          </form>
        </div>
      </bs-navbar>
    </header>

    <main class="flex-shrink-0">
      <div class="container">
        <h1 class="mt-5">Sticky footer with fixed navbar</h1>
        <p class="lead">Pin a footer to the bottom of the viewport in desktop browsers with this custom HTML and CSS. A fixed navbar has been added with <code class="small">padding-top: 60px;</code> on the <code class="small">main &gt; .container</code>.</p>
        <p>Back to <a href="/examples/sticky-footer/">the default sticky footer</a> minus the navbar.</p>
      </div>
    </main>

    <footer class="footer mt-auto py-3 bg-body-tertiary">
      <div class="container">
        <span class="text-body-secondary">Place sticky footer content here.</span>
      </div>
    </footer>
  </body>
</html>
