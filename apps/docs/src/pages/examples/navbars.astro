---
// Standalone port of https://getbootstrap.com/docs/5.3/examples/navbars/
// to bootstrap-wc components. Comparator pair lives at
// apps/docs/src/pages/compare/example-navbars/.

---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Navbars example · bootstrap-wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
        padding-bottom: 20px;
      }
      bs-navbar {
        margin-bottom: 20px;
      }
    </style>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body>
    <main>
      <!-- 1. Never expand (always collapsed) -->
      <bs-navbar expand="never" theme="dark" background="dark" aria-label="First navbar example">
        <span slot="brand">Never expand</span>
        <bs-nav class="me-auto mb-2">
          <bs-nav-item href="#" active>Home</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
          <bs-nav-item disabled>Disabled</bs-nav-item>
        </bs-nav>
        <form class="d-flex" role="search">
          <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
          <bs-button variant="success" button-style="outline" type="submit">Search</bs-button>
        </form>
      </bs-navbar>

      <!-- 2. Always expand -->
      <bs-navbar expand="always" theme="dark" background="dark" aria-label="Second navbar example">
        <span slot="brand">Always expand</span>
        <bs-nav class="me-auto">
          <bs-nav-item href="#" active>Home</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
        </bs-nav>
        <form slot="end" role="search">
          <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
        </form>
      </bs-navbar>

      <!-- 3. Expand at sm -->
      <bs-navbar expand="sm" theme="dark" background="dark" aria-label="Third navbar example">
        <span slot="brand">Expand at sm</span>
        <bs-nav class="me-auto mb-2 mb-sm-0">
          <bs-nav-item href="#" active>Home</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
          <bs-nav-item disabled>Disabled</bs-nav-item>
        </bs-nav>
        <form slot="end" role="search">
          <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
        </form>
      </bs-navbar>

      <!-- 4. Expand at md -->
      <bs-navbar expand="md" theme="dark" background="dark" aria-label="Fourth navbar example">
        <span slot="brand">Expand at md</span>
        <bs-nav class="me-auto mb-2 mb-md-0">
          <bs-nav-item href="#" active>Home</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
          <bs-nav-item disabled>Disabled</bs-nav-item>
        </bs-nav>
        <form slot="end" role="search">
          <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
        </form>
      </bs-navbar>

      <!-- 5. Expand at lg -->
      <bs-navbar expand="lg" theme="dark" background="dark" aria-label="Fifth navbar example">
        <span slot="brand">Expand at lg</span>
        <bs-nav class="me-auto mb-2 mb-lg-0">
          <bs-nav-item href="#" active>Home</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
          <bs-nav-item disabled>Disabled</bs-nav-item>
        </bs-nav>
        <form slot="end" role="search">
          <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
        </form>
      </bs-navbar>

      <!-- 6. Expand at xl -->
      <bs-navbar expand="xl" theme="dark" background="dark" aria-label="Sixth navbar example">
        <span slot="brand">Expand at xl</span>
        <bs-nav class="me-auto mb-2 mb-xl-0">
          <bs-nav-item href="#" active>Home</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
          <bs-nav-item disabled>Disabled</bs-nav-item>
        </bs-nav>
        <form slot="end" role="search">
          <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
        </form>
      </bs-navbar>

      <!-- 7. Expand at xxl -->
      <bs-navbar expand="xxl" theme="dark" background="dark" aria-label="Seventh navbar example">
        <span slot="brand">Expand at xxl</span>
        <bs-nav class="me-auto mb-2 mb-xl-0">
          <bs-nav-item href="#" active>Home</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
          <bs-nav-item disabled>Disabled</bs-nav-item>
        </bs-nav>
        <form slot="end" role="search">
          <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
        </form>
      </bs-navbar>

      <!-- 8. Container (responsive) -->
      <bs-navbar expand="lg" theme="dark" background="dark" container="default" aria-label="Eighth navbar example">
        <span slot="brand">Container</span>
        <bs-nav class="me-auto mb-2 mb-lg-0">
          <bs-nav-item href="#" active>Home</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
        </bs-nav>
        <form slot="end" role="search">
          <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
        </form>
      </bs-navbar>

      <!-- 9. Container XL -->
      <bs-navbar expand="lg" theme="dark" background="dark" container="xl" aria-label="Ninth navbar example">
        <span slot="brand">Container XL</span>
        <bs-nav class="me-auto mb-2 mb-lg-0">
          <bs-nav-item href="#" active>Home</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
        </bs-nav>
        <form slot="end" role="search">
          <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
        </form>
      </bs-navbar>

      <div class="container-xl mb-4">
        <p>Matching .container-xl...</p>
      </div>

      <!-- 10. Centered nav only (dark) -->
      <bs-navbar expand="lg" theme="dark" background="dark" aria-label="Tenth navbar example">
        <bs-nav class="justify-content-md-center w-100">
          <bs-nav-item href="#" active>Centered nav only</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
        </bs-nav>
      </bs-navbar>

      <!-- 11-13 wrapped in a .container -->
      <div class="container">
        <!-- 11. Light tertiary in container -->
        <bs-navbar expand="lg" background="body-tertiary" class="rounded" aria-label="Eleventh navbar example">
          <span slot="brand">Navbar</span>
          <bs-nav class="me-auto mb-2 mb-lg-0">
            <bs-nav-item href="#" active>Home</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
          </bs-nav>
          <form slot="end" role="search">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </bs-navbar>

        <!-- 12. Centered nav only (light) -->
        <bs-navbar expand="lg" background="body-tertiary" class="rounded mt-3" aria-label="Twelfth navbar example">
          <bs-nav class="justify-content-md-center w-100">
            <bs-nav-item href="#" active>Centered nav only</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
          </bs-nav>
        </bs-navbar>

        <!-- 13. Centered nav with brand split -->
        <bs-navbar expand="lg" background="body-tertiary" class="rounded mt-3" aria-label="Thirteenth navbar example">
          <a class="navbar-brand col-lg-3 me-0" href="#">Centered nav</a>
          <bs-nav class="col-lg-6 justify-content-lg-center">
            <bs-nav-item href="#" active>Home</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
          </bs-nav>
          <bs-nav slot="end" class="col-lg-3 justify-content-lg-end">
            <bs-nav-item href="#">Sign up</bs-nav-item>
          </bs-nav>
        </bs-navbar>
      </div>

      <div class="container my-5">
        <div class="bg-body-tertiary p-5 rounded">
          <div class="col-sm-8 mx-auto">
            <h1>Navbar examples</h1>
            <p>This example is a quick exercise to illustrate how the navbar and its contents work. Some navbars extend the width of the viewport, others are confined within a <code>.container</code>. For positioning of navbars, checkout the <a href="#">top</a> and <a href="#">fixed top</a> examples.</p>
            <p>At the smallest breakpoint, the collapse plugin is used to hide the links and show a menu button to toggle the collapsed content.</p>
            <p>
              <bs-button variant="primary" href="#">View navbar docs &raquo;</bs-button>
            </p>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
