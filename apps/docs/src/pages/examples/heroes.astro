---
// Standalone port of https://getbootstrap.com/docs/5.3/examples/heroes/
// to bootstrap-wc components. Comparator pair lives at
// apps/docs/src/pages/compare/example-heroes/.

---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Heroes example · bootstrap-wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .placeholder-img {
        display: block;
        width: 700px;
        max-width: 100%;
        height: 200px;
        background:
          linear-gradient(135deg, #dee2e6 25%, transparent 25%) -10px 0 / 20px 20px,
          linear-gradient(225deg, #dee2e6 25%, transparent 25%) -10px 0 / 20px 20px,
          linear-gradient(315deg, #dee2e6 25%, transparent 25%) 0 0 / 20px 20px,
          linear-gradient(45deg, #dee2e6 25%, transparent 25%) 0 0 / 20px 20px;
        background-color: #f8f9fa;
      }
    </style>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body>
    <main>
      <div class="px-4 py-5 my-5 text-center">
        <h1 class="display-5 fw-bold text-body-emphasis">Centered hero</h1>
        <div class="col-lg-6 mx-auto">
          <p class="lead mb-4">Quickly design and customize responsive mobile-first sites with Bootstrap, the world's most popular front-end open source toolkit, featuring Sass variables and mixins, responsive grid system, extensive prebuilt components, and powerful JavaScript plugins.</p>
          <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <bs-button variant="primary" size="lg" class="px-4 gap-3">Primary button</bs-button>
            <bs-button variant="secondary" button-style="outline" size="lg" class="px-4">Secondary</bs-button>
          </div>
        </div>
      </div>

      <div class="px-4 py-5 my-5">
        <div class="row gx-5 align-items-center">
          <div class="col-lg-6">
            <h2 class="display-5 fw-bold text-body-emphasis mb-4">Responsive left-aligned hero with image</h2>
            <p class="lead">Quickly design and customize responsive mobile-first sites with Bootstrap, the world's most popular front-end open source toolkit, featuring Sass variables and mixins, responsive grid system, extensive prebuilt components, and powerful JavaScript plugins.</p>
            <div class="d-grid gap-2 d-sm-flex">
              <bs-button variant="primary" size="lg" class="px-4 gap-3">Primary</bs-button>
              <bs-button variant="secondary" button-style="outline" size="lg" class="px-4">Default</bs-button>
            </div>
          </div>
          <div class="col-lg-6 overflow-hidden">
            <div class="placeholder-img border rounded-3 shadow-lg mb-4 mx-auto"></div>
          </div>
        </div>
      </div>

      <div class="px-4 py-5 my-5 text-center">
        <h2 class="display-5 fw-bold text-body-emphasis mb-4">Vertically centered hero sign-up form</h2>
        <div class="col-lg-6 mx-auto">
          <p class="lead mb-4">Below is an example form built entirely with Bootstrap's form controls. Each required form group has a validation state.</p>
          <form class="needs-validation" novalidate>
            <div class="mb-3">
              <label for="inputEmail" class="form-label">Email address</label>
              <input type="email" class="form-control" id="inputEmail" placeholder="you@example.com" required />
            </div>
            <div class="mb-3">
              <label for="inputPassword" class="form-label">Password</label>
              <input type="password" class="form-control" id="inputPassword" placeholder="Password" required />
            </div>
            <div class="mb-3">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="gridCheck" required />
                <label class="form-check-label" for="gridCheck">Remember me</label>
              </div>
            </div>
            <div class="d-grid">
              <bs-button variant="primary" size="lg" type="submit">Sign up</bs-button>
            </div>
            <hr class="my-4" />
            <small class="text-body-secondary">By clicking Sign up, you agree to the terms of use.</small>
          </form>
        </div>
      </div>

      <div class="px-4 py-5 text-center" style="background-color: #2c3e50;">
        <h2 class="display-5 fw-bold text-white mb-4">Dark color hero</h2>
        <div class="col-lg-6 mx-auto">
          <p class="lead text-white mb-4">Quickly design and customize responsive mobile-first sites with Bootstrap, the world's most popular front-end open source toolkit.</p>
          <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <bs-button variant="light" size="lg" class="px-4 gap-3">Custom button</bs-button>
            <bs-button variant="light" button-style="outline" size="lg" class="px-4">Secondary</bs-button>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
