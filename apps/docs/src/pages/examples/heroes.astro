---
// Standalone port of https://getbootstrap.com/docs/5.3/examples/heroes/
// to bootstrap-wc components. Comparator pair lives at
// apps/docs/src/pages/compare/example-heroes/.

---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Heroes example · bootstrap-wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .b-example-divider {
        width: 100%;
        height: 3rem;
        background-color: rgba(0, 0, 0, 0.1);
        border: solid rgba(0, 0, 0, 0.15);
        border-width: 1px 0;
        box-shadow:
          inset 0 0.5em 1.5em rgba(0, 0, 0, 0.1),
          inset 0 0.125em 0.5em rgba(0, 0, 0, 0.15);
      }
      .placeholder-img {
        display: block;
        width: 700px;
        max-width: 100%;
        height: 200px;
        background:
          linear-gradient(135deg, #dee2e6 25%, transparent 25%) -10px 0 / 20px 20px,
          linear-gradient(225deg, #dee2e6 25%, transparent 25%) -10px 0 / 20px 20px,
          linear-gradient(315deg, #dee2e6 25%, transparent 25%) 0 0 / 20px 20px,
          linear-gradient(45deg, #dee2e6 25%, transparent 25%) 0 0 / 20px 20px;
        background-color: #f8f9fa;
      }
      .placeholder-img-tall {
        height: 500px;
      }
      .placeholder-img-wide {
        width: 100%;
        max-width: 720px;
        height: 360px;
      }
      .rounded-lg-3 {
        border-radius: 0.3rem;
      }
      .placeholder-logo {
        display: inline-block;
        width: 72px;
        height: 57px;
        background-color: #dee2e6;
        border-radius: 8px;
      }
    </style>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body>
    <main>
      <!-- 1. Centered hero -->
      <div class="px-4 py-5 my-5 text-center">
        <span class="placeholder-logo d-block mx-auto mb-4"></span>
        <h1 class="display-5 fw-bold text-body-emphasis">Centered hero</h1>
        <div class="col-lg-6 mx-auto">
          <p class="lead mb-4">Quickly design and customize responsive mobile-first sites with Bootstrap, the world's most popular front-end open source toolkit, featuring Sass variables and mixins, responsive grid system, extensive prebuilt components, and powerful JavaScript plugins.</p>
          <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <bs-button variant="primary" size="lg" class="px-4 gap-3">Primary button</bs-button>
            <bs-button variant="secondary" button-style="outline" size="lg" class="px-4">Secondary</bs-button>
          </div>
        </div>
      </div>

      <div class="b-example-divider"></div>

      <!-- 2. Centered screenshot -->
      <div class="px-4 pt-5 my-5 text-center border-bottom">
        <h1 class="display-4 fw-bold text-body-emphasis">Centered screenshot</h1>
        <div class="col-lg-6 mx-auto">
          <p class="lead mb-4">Quickly design and customize responsive mobile-first sites with Bootstrap, the world's most popular front-end open source toolkit, featuring Sass variables and mixins, responsive grid system, extensive prebuilt components, and powerful JavaScript plugins.</p>
          <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mb-5">
            <bs-button variant="primary" size="lg" class="px-4 me-sm-3">Primary button</bs-button>
            <bs-button variant="secondary" button-style="outline" size="lg" class="px-4">Secondary</bs-button>
          </div>
        </div>
        <div class="overflow-hidden" style="max-height: 30vh;">
          <div class="container px-5">
            <div class="placeholder-img placeholder-img-tall border rounded-3 shadow-lg mb-4 mx-auto"></div>
          </div>
        </div>
      </div>

      <div class="b-example-divider"></div>

      <!-- 3. Responsive left-aligned hero with image -->
      <div class="container col-xxl-8 px-4 py-5">
        <div class="row flex-lg-row-reverse align-items-center g-5 py-5">
          <div class="col-10 col-sm-8 col-lg-6">
            <div class="placeholder-img d-block mx-lg-auto"></div>
          </div>
          <div class="col-lg-6">
            <h1 class="display-5 fw-bold text-body-emphasis lh-1 mb-3">Responsive left-aligned hero with image</h1>
            <p class="lead">Quickly design and customize responsive mobile-first sites with Bootstrap, the world's most popular front-end open source toolkit, featuring Sass variables and mixins, responsive grid system, extensive prebuilt components, and powerful JavaScript plugins.</p>
            <div class="d-grid gap-2 d-md-flex justify-content-md-start">
              <bs-button variant="primary" size="lg" class="px-4 me-md-2">Primary</bs-button>
              <bs-button variant="secondary" button-style="outline" size="lg" class="px-4">Default</bs-button>
            </div>
          </div>
        </div>
      </div>

      <div class="b-example-divider"></div>

      <!-- 4. Vertically centered hero sign-up form -->
      <div class="container col-xl-10 col-xxl-8 px-4 py-5">
        <div class="row align-items-center g-lg-5 py-5">
          <div class="col-lg-7 text-center text-lg-start">
            <h1 class="display-4 fw-bold lh-1 text-body-emphasis mb-3">Vertically centered hero sign-up form</h1>
            <p class="col-lg-10 fs-4">Below is an example form built entirely with Bootstrap's form controls. Each required form group has a validation state that can be triggered by attempting to submit the form without completing it.</p>
          </div>
          <div class="col-md-10 mx-auto col-lg-5">
            <form class="p-4 p-md-5 border rounded-3 bg-body-tertiary">
              <div class="form-floating mb-3">
                <input type="email" class="form-control" id="floatingInput" placeholder="name@example.com" />
                <label for="floatingInput">Email address</label>
              </div>
              <div class="form-floating mb-3">
                <input type="password" class="form-control" id="floatingPassword" placeholder="Password" />
                <label for="floatingPassword">Password</label>
              </div>
              <div class="checkbox mb-3">
                <label>
                  <input type="checkbox" value="remember-me" /> Remember me
                </label>
              </div>
              <bs-button variant="primary" size="lg" type="submit" class="w-100">Sign up</bs-button>
              <hr class="my-4" />
              <small class="text-body-secondary">By clicking Sign up, you agree to the terms of use.</small>
            </form>
          </div>
        </div>
      </div>

      <div class="b-example-divider"></div>

      <!-- 5. Border hero with cropped image and shadows -->
      <div class="container my-5">
        <div class="row p-4 pb-0 pe-lg-0 pt-lg-5 align-items-center rounded-3 border shadow-lg">
          <div class="col-lg-7 p-3 p-lg-5 pt-lg-3">
            <h1 class="display-4 fw-bold lh-1 text-body-emphasis">Border hero with cropped image and shadows</h1>
            <p class="lead">Quickly design and customize responsive mobile-first sites with Bootstrap, the world's most popular front-end open source toolkit, featuring Sass variables and mixins, responsive grid system, extensive prebuilt components, and powerful JavaScript plugins.</p>
            <div class="d-grid gap-2 d-md-flex justify-content-md-start mb-4 mb-lg-3">
              <bs-button variant="primary" size="lg" class="px-4 me-md-2 fw-bold">Primary</bs-button>
              <bs-button variant="secondary" button-style="outline" size="lg" class="px-4">Default</bs-button>
            </div>
          </div>
          <div class="col-lg-4 offset-lg-1 p-0 overflow-hidden shadow-lg">
            <div class="placeholder-img placeholder-img-wide rounded-lg-3"></div>
          </div>
        </div>
      </div>

      <div class="b-example-divider"></div>

      <!-- 6. Dark color hero -->
      <div class="bg-dark text-secondary px-4 py-5 text-center">
        <div class="py-5">
          <h1 class="display-5 fw-bold text-white">Dark color hero</h1>
          <div class="col-lg-6 mx-auto">
            <p class="fs-5 mb-4">Quickly design and customize responsive mobile-first sites with Bootstrap, the world's most popular front-end open source toolkit, featuring Sass variables and mixins, responsive grid system, extensive prebuilt components, and powerful JavaScript plugins.</p>
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
              <bs-button variant="info" button-style="outline" size="lg" class="px-4 me-sm-3 fw-bold">Custom button</bs-button>
              <bs-button variant="light" button-style="outline" size="lg" class="px-4">Secondary</bs-button>
            </div>
          </div>
        </div>
      </div>

      <div class="b-example-divider mb-0"></div>
    </main>
  </body>
</html>
