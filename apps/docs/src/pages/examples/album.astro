---
import DocsLayout from '../../layouts/DocsLayout.astro';

// Album example template — ported from
// https://getbootstrap.com/docs/5.3/examples/album/ to <bs-*> components.
// See apps/docs/src/pages/compare/example-album/ for the side-by-side
// reference + wc pair the comparator validates against.

const cards = [1, 2, 3, 4, 5, 6, 7, 8, 9];
const cardText =
  'This is a wider card with supporting text below as a natural lead-in to additional content. This content is a little bit longer.';
const placeholderSvg =
  'data:image/svg+xml;utf8,' +
  encodeURIComponent(
    '<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="225" preserveAspectRatio="xMidYMid slice" focusable="false" role="img" viewBox="0 0 318 225"><rect width="100%" height="100%" fill="#55595c"/><text x="50%" y="50%" fill="#eceeef" dy=".3em" text-anchor="middle" font-family="system-ui,sans-serif" font-size="18">Thumbnail</text></svg>',
  );
---

<DocsLayout title="Album" description="Album example template — a one-page photo gallery layout built with bootstrap-wc components." activeSlug="examples">
  <header data-bs-theme="dark">
    <div class="navbar navbar-dark bg-dark shadow-sm rounded">
      <div class="container">
        <a href="#" class="navbar-brand d-flex align-items-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" aria-hidden="true" class="me-2" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          <strong>Album</strong>
        </a>
      </div>
    </div>
  </header>

  <section class="py-5 text-center container">
    <div class="row py-lg-5">
      <div class="col-lg-6 col-md-8 mx-auto">
        <h1 class="fw-light">Album example</h1>
        <p class="lead text-body-secondary">
          Something short and leading about the collection below—its contents,
          the creator, etc. Make it short and sweet, but not too short so
          folks don't simply skip over it entirely.
        </p>
        <p>
          <bs-button variant="primary" href="#" class="my-2">Main call to action</bs-button>
          <bs-button variant="secondary" href="#" class="my-2">Secondary action</bs-button>
        </p>
      </div>
    </div>
  </section>

  <div class="album py-5 bg-body-tertiary rounded">
    <div class="container">
      <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
        {cards.map((n) => (
          <div class="col">
            <bs-card no-body class="shadow-sm">
              <img slot="image" src={placeholderSvg} alt={`Thumbnail ${n}`} class="card-img-top" />
              <div class="card-body">
                <p class="card-text">{cardText}</p>
                <div class="d-flex justify-content-between align-items-center">
                  <bs-button-group>
                    <bs-button variant="secondary" button-style="outline" size="sm">View</bs-button>
                    <bs-button variant="secondary" button-style="outline" size="sm">Edit</bs-button>
                  </bs-button-group>
                  <small class="text-body-secondary">9 mins</small>
                </div>
              </div>
            </bs-card>
          </div>
        ))}
      </div>
    </div>
  </div>

  <footer class="text-body-secondary py-5">
    <div class="container">
      <p class="float-end mb-1">
        <a href="#">Back to top</a>
      </p>
      <p class="mb-1">Album example is &copy; Bootstrap, ported to <a href="/components/card/">@bootstrap-wc/components</a> — fork it for your own gallery.</p>
      <p class="mb-0">New here? Read the <a href="/getting-started/introduction/">getting started guide</a>.</p>
    </div>
  </footer>
</DocsLayout>
