---
// Standalone port of https://getbootstrap.com/docs/5.3/examples/modals/
// to bootstrap-wc components. Comparator pair lives at
// apps/docs/src/pages/compare/example-modals/.

---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Modals example · bootstrap-wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .b-example-divider {
        width: 100%;
        height: 3rem;
        background-color: rgba(0, 0, 0, 0.1);
        border: solid rgba(0, 0, 0, 0.15);
        border-width: 1px 0;
        box-shadow:
          inset 0 0.5em 1.5em rgba(0, 0, 0, 0.1),
          inset 0 0.125em 0.5em rgba(0, 0, 0, 0.15);
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body>
    <bs-modal
      static-display
      heading="Modal title"
      modal-class="modal-sheet bg-body-secondary p-4 py-md-5"
      content-class="rounded-4 shadow"
      header-class="border-bottom-0"
      body-class="py-0"
      footer-class="flex-column align-items-stretch w-100 gap-2 pb-3 border-top-0"
      id="modalSheet"
    >
      <p>This is a modal sheet, a variation of the modal that docks itself to the bottom of the viewport like the newer share sheets in iOS.</p>
      <bs-button slot="footer" variant="primary" size="lg">Save changes</bs-button>
      <bs-button slot="footer" variant="secondary" size="lg" data-bs-dismiss="modal">Close</bs-button>
    </bs-modal>
    <div class="b-example-divider"></div>

    <bs-modal
      static-display
      no-close-button
      modal-class="modal-sheet bg-body-secondary p-4 py-md-5"
      content-class="rounded-3 shadow"
      body-class="p-4 text-center"
      footer-class="flex-nowrap p-0"
      id="modalChoice"
    >
      <h5 class="mb-0">Enable this setting?</h5>
      <p class="mb-0">You can always change your mind in your account settings.</p>
      <bs-button slot="footer" button-style="link" size="lg" class="fs-6 text-decoration-none col-6 py-3 m-0 rounded-0 border-end"><strong>Yes, enable</strong></bs-button>
      <bs-button slot="footer" button-style="link" size="lg" class="fs-6 text-decoration-none col-6 py-3 m-0 rounded-0" data-bs-dismiss="modal">No thanks</bs-button>
    </bs-modal>
    <div class="b-example-divider"></div>
  </body>
</html>
