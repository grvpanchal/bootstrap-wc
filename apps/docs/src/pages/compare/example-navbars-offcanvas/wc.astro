---
// `<bs-*>` port of ./reference.astro for the Navbars Offcanvas example.
// bs-navbar provides the .navbar chrome on the host; togglers and the
// offcanvas drawers are native markup so Bootstrap's bundle JS handles
// both the toggle behavior and the slide-in animation. The third nav
// uses `.offcanvas-end` paired with `.navbar-expand-lg` so it behaves
// as a drawer below lg and an inline column at lg+.
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Navbars offcanvas wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body data-compare-key="root">
    <main>
      <bs-navbar expand="never" theme="dark" background="dark" container="fluid" aria-label="Dark offcanvas navbar" data-compare-key="oc-dark">
        <a class="navbar-brand" href="#">Dark offcanvas navbar</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#oc-dark-offcanvas" aria-controls="oc-dark-offcanvas" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="offcanvas offcanvas-end text-bg-dark" tabindex="-1" id="oc-dark-offcanvas" aria-labelledby="oc-dark-offcanvas-label">
          <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="oc-dark-offcanvas-label">Offcanvas</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
          </div>
          <div class="offcanvas-body">
            <bs-nav class="justify-content-end flex-grow-1 pe-3">
              <bs-nav-item href="#" active>Home</bs-nav-item>
              <bs-nav-item href="#">Link</bs-nav-item>
              <bs-nav-item href="#">Dropdown</bs-nav-item>
            </bs-nav>
            <form class="d-flex mt-3" role="search">
              <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
              <bs-button variant="success" button-style="outline" type="submit">Search</bs-button>
            </form>
          </div>
        </div>
      </bs-navbar>

      <bs-navbar expand="never" background="body-tertiary" container="fluid" aria-label="Light offcanvas navbar" data-compare-key="oc-light">
        <a class="navbar-brand" href="#">Light offcanvas navbar</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#oc-light-offcanvas" aria-controls="oc-light-offcanvas" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="offcanvas offcanvas-end" tabindex="-1" id="oc-light-offcanvas" aria-labelledby="oc-light-offcanvas-label">
          <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="oc-light-offcanvas-label">Offcanvas</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
          </div>
          <div class="offcanvas-body">
            <bs-nav class="justify-content-end flex-grow-1 pe-3">
              <bs-nav-item href="#" active>Home</bs-nav-item>
              <bs-nav-item href="#">Link</bs-nav-item>
              <bs-nav-item href="#">Dropdown</bs-nav-item>
            </bs-nav>
            <form class="d-flex mt-3" role="search">
              <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
              <bs-button variant="success" button-style="outline" type="submit">Search</bs-button>
            </form>
          </div>
        </div>
      </bs-navbar>

      <bs-navbar expand="lg" theme="dark" background="dark" container="fluid" aria-label="Offcanvas navbar large" data-compare-key="oc-responsive">
        <a class="navbar-brand" href="#">Responsive offcanvas navbar</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#oc-responsive-offcanvas" aria-controls="oc-responsive-offcanvas" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="offcanvas offcanvas-end text-bg-dark" tabindex="-1" id="oc-responsive-offcanvas" aria-labelledby="oc-responsive-offcanvas-label">
          <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="oc-responsive-offcanvas-label">Offcanvas</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
          </div>
          <div class="offcanvas-body">
            <bs-nav class="justify-content-end flex-grow-1 pe-3">
              <bs-nav-item href="#" active>Home</bs-nav-item>
              <bs-nav-item href="#">Link</bs-nav-item>
              <bs-nav-item href="#">Dropdown</bs-nav-item>
            </bs-nav>
            <form class="d-flex mt-3 mt-lg-0" role="search">
              <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
              <bs-button variant="success" button-style="outline" type="submit">Search</bs-button>
            </form>
          </div>
        </div>
      </bs-navbar>

      <div class="container my-5" data-compare-key="hero-wrap">
        <div class="bg-body-tertiary p-5 rounded" data-compare-key="hero">
          <div class="col-sm-8 py-5 mx-auto">
            <h1 class="display-5 fw-normal" data-compare-key="hero-title">Navbar with offcanvas examples</h1>
            <p class="fs-5" data-compare-key="hero-lead">This example shows how responsive offcanvas menus work within the navbar. For positioning of navbars, checkout the <a href="#">top</a> and <a href="#">fixed top</a> examples.</p>
            <p class="fs-5" data-compare-key="hero-lead-2">From the top down, you'll see a dark navbar, light navbar and a responsive navbar—each with offcanvases built in. Resize your browser window to the large breakpoint to see the toggle for the offcanvas.</p>
            <p data-compare-key="hero-actions">
              <bs-button variant="primary" href="/components/offcanvas/" data-compare-key="hero-cta">Learn more about offcanvas navbars &raquo;</bs-button>
            </p>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
