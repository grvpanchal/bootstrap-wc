---
// `<bs-*>` port of ./reference.astro for the Navbars Offcanvas example.
// Three <bs-navbar>s, each with a <bs-offcanvas> drawer (the third uses
// `responsive="lg"` so it folds inline at lg+ rather than opening as a
// drawer). Light-DOM `<button>`s wired with a small inline script call
// the offcanvas's show() method.
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Navbars offcanvas wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
    </style>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body data-compare-key="root">
    <main>
      <bs-navbar expand="never" theme="dark" background="dark" aria-label="Dark offcanvas navbar" data-compare-key="oc-dark">
        <span slot="brand">Dark offcanvas navbar</span>
      </bs-navbar>

      <bs-navbar expand="never" background="body-tertiary" aria-label="Light offcanvas navbar" data-compare-key="oc-light">
        <span slot="brand">Light offcanvas navbar</span>
      </bs-navbar>

      <bs-navbar expand="lg" theme="dark" background="dark" aria-label="Offcanvas navbar large" data-compare-key="oc-responsive">
        <span slot="brand">Responsive offcanvas navbar</span>
        <bs-nav class="justify-content-end flex-grow-1 pe-3" data-compare-key="oc-responsive-nav">
          <bs-nav-item href="#" active>Home</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
          <bs-nav-item href="#">Dropdown</bs-nav-item>
        </bs-nav>
        <form slot="end" class="d-flex mt-3 mt-lg-0" role="search" data-compare-key="oc-responsive-form">
          <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
          <bs-button variant="success" button-style="outline" type="submit" data-compare-key="oc-responsive-submit">Search</bs-button>
        </form>
      </bs-navbar>

      <div class="container my-5" data-compare-key="hero-wrap">
        <div class="bg-body-tertiary p-5 rounded" data-compare-key="hero">
          <div class="col-sm-8 py-5 mx-auto">
            <h1 class="display-5 fw-normal" data-compare-key="hero-title">Navbar with offcanvas examples</h1>
            <p class="fs-5" data-compare-key="hero-lead">This example shows how responsive offcanvas menus work within the navbar. For positioning of navbars, checkout the <a href="#">top</a> and <a href="#">fixed top</a> examples.</p>
            <p class="fs-5" data-compare-key="hero-lead-2">From the top down, you'll see a dark navbar, light navbar and a responsive navbar—each with offcanvases built in. Resize your browser window to the large breakpoint to see the toggle for the offcanvas.</p>
            <p data-compare-key="hero-actions">
              <bs-button variant="primary" href="#" data-compare-key="hero-cta">Learn more about offcanvas navbars &raquo;</bs-button>
            </p>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
