---
// `<bs-*>` port of ./reference.astro for the Badges snippet page.
// Uses <bs-badge> for every variant: solid (default tone), subtle
// (tone="subtle"), bordered subtle (tone="bordered"), with image
// (slotted children + tone="bordered"), and dismissible (tone="solid"
// or "subtle" with the dismissible attribute).
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Badges wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .b-example-divider {
        width: 100%;
        height: 3rem;
        background-color: rgba(0, 0, 0, 0.1);
        border: solid rgba(0, 0, 0, 0.15);
        border-width: 1px 0;
        box-shadow:
          inset 0 0.5em 1.5em rgba(0, 0, 0, 0.1),
          inset 0 0.125em 0.5em rgba(0, 0, 0, 0.15);
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body data-compare-key="root">
    <svg xmlns="http://www.w3.org/2000/svg" class="d-none">
      <symbol id="x-circle-fill" viewBox="0 0 16 16">
        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293 5.354 4.646z"></path>
      </symbol>
    </svg>

    <div class="d-flex gap-2 justify-content-center py-5" data-compare-key="row-solid">
      <bs-badge variant="primary" pill>Primary</bs-badge>
      <bs-badge variant="secondary" pill>Secondary</bs-badge>
      <bs-badge variant="success" pill>Success</bs-badge>
      <bs-badge variant="danger" pill>Danger</bs-badge>
      <bs-badge variant="warning" pill>Warning</bs-badge>
      <bs-badge variant="info" pill>Info</bs-badge>
      <bs-badge variant="light" pill>Light</bs-badge>
      <bs-badge variant="dark" pill>Dark</bs-badge>
    </div>
    <div class="b-example-divider"></div>
    <div class="d-flex gap-2 justify-content-center py-5" data-compare-key="row-subtle">
      <bs-badge variant="primary" tone="subtle" pill>Primary</bs-badge>
      <bs-badge variant="secondary" tone="subtle" pill>Secondary</bs-badge>
      <bs-badge variant="success" tone="subtle" pill>Success</bs-badge>
      <bs-badge variant="danger" tone="subtle" pill>Danger</bs-badge>
      <bs-badge variant="warning" tone="subtle" pill>Warning</bs-badge>
      <bs-badge variant="info" tone="subtle" pill>Info</bs-badge>
      <bs-badge variant="light" tone="subtle" pill>Light</bs-badge>
      <bs-badge variant="dark" tone="subtle" pill>Dark</bs-badge>
    </div>
    <div class="b-example-divider"></div>
    <div class="d-flex gap-2 justify-content-center py-5" data-compare-key="row-bordered">
      <bs-badge variant="primary" tone="bordered" pill>Primary</bs-badge>
      <bs-badge variant="secondary" tone="bordered" pill>Secondary</bs-badge>
      <bs-badge variant="success" tone="bordered" pill>Success</bs-badge>
      <bs-badge variant="danger" tone="bordered" pill>Danger</bs-badge>
      <bs-badge variant="warning" tone="bordered" pill>Warning</bs-badge>
      <bs-badge variant="info" tone="bordered" pill>Info</bs-badge>
      <bs-badge variant="light" tone="bordered" pill>Light</bs-badge>
      <bs-badge variant="dark" tone="bordered" pill>Dark</bs-badge>
    </div>
    <div class="b-example-divider"></div>
    <div class="d-flex gap-2 justify-content-center py-5" data-compare-key="row-with-image">
      <bs-badge variant="primary" tone="bordered" pill class="d-flex align-items-center p-1 pe-2">
        <span class="rounded-circle me-1 d-inline-block bg-primary" style="width:24px;height:24px"></span>Primary
      </bs-badge>
    </div>
    <div class="b-example-divider"></div>
    <div class="d-flex gap-2 justify-content-center py-5" data-compare-key="row-removable">
      <span class="badge d-flex p-2 align-items-center text-bg-primary rounded-pill">
        <span class="px-1">Primary 1</span>
        <a href="#" aria-label="Delete primary 1"><svg class="bi ms-1" width="16" height="16" aria-hidden="true"><use xlink:href="#x-circle-fill"></use></svg></a>
      </span>
      <span class="badge d-flex p-2 align-items-center text-primary-emphasis bg-primary-subtle rounded-pill">
        <span class="px-1">Primary 2</span>
        <a href="#" aria-label="Delete primary 2"><svg class="bi ms-1" width="16" height="16" aria-hidden="true"><use xlink:href="#x-circle-fill"></use></svg></a>
      </span>
    </div>
    <div class="b-example-divider"></div>
  </body>
</html>
