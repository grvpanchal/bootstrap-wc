---
// Plain Bootstrap reference for the Sticky-footer-navbar example template.
// Mirrors https://getbootstrap.com/docs/5.3/examples/sticky-footer-navbar/.
---

<!doctype html>
<html lang="en" class="h-100" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sticky footer navbar reference</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      main > .container {
        padding: 60px 15px 0;
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </head>
  <body class="d-flex flex-column h-100" data-compare-key="root">
    <header data-compare-key="sfn-header">
      <nav class="navbar navbar-expand-md navbar-dark fixed-top bg-dark" data-compare-key="sfn-navbar">
        <div class="container-fluid">
          <a class="navbar-brand" href="#">Fixed navbar</a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarCollapse">
            <ul class="navbar-nav me-auto mb-2 mb-md-0" data-compare-key="sfn-nav-list">
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
              <li class="nav-item"><a class="nav-link disabled" aria-disabled="true">Disabled</a></li>
            </ul>
            <form class="d-flex" role="search" data-compare-key="sfn-search">
              <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
              <button class="btn btn-outline-success" type="submit" data-compare-key="sfn-search-submit">Search</button>
            </form>
          </div>
        </div>
      </nav>
    </header>

    <main class="flex-shrink-0" data-compare-key="sfn-main">
      <div class="container" data-compare-key="sfn-main-container">
        <h1 class="mt-5" data-compare-key="sfn-main-title">Sticky footer with fixed navbar</h1>
        <p class="lead" data-compare-key="sfn-main-lead">Pin a footer to the bottom of the viewport in desktop browsers with this custom HTML and CSS. A fixed navbar has been added with <code class="small">padding-top: 60px;</code> on the <code class="small">main &gt; .container</code>.</p>
        <p data-compare-key="sfn-main-text">Back to <a href="/examples/sticky-footer/" data-compare-key="sfn-main-link">the default sticky footer</a> minus the navbar.</p>
      </div>
    </main>

    <footer class="footer mt-auto py-3 bg-body-tertiary" data-compare-key="sfn-footer">
      <div class="container" data-compare-key="sfn-footer-container">
        <span class="text-body-secondary" data-compare-key="sfn-footer-text">Place sticky footer content here.</span>
      </div>
    </footer>
  </body>
</html>
