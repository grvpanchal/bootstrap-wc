---
// `<bs-*>` port of ./reference.astro for the Footers example template.
// `bs-nav` doesn't add value over the native `<ul class="nav">` here
// since each variant's nav has fine-grained utility classes (col-md-4,
// flex-column, justify-content-end, etc.) — keep these as native ULs.
// The newsletter subscribe button → `<bs-button>`.
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Footers wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .b-example-divider {
        width: 100%;
        height: 3rem;
        background-color: rgba(0, 0, 0, 0.1);
        border: solid rgba(0, 0, 0, 0.15);
        border-width: 1px 0;
        box-shadow:
          inset 0 0.5em 1.5em rgba(0, 0, 0, 0.1),
          inset 0 0.125em 0.5em rgba(0, 0, 0, 0.15);
      }
    </style>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body data-compare-key="root">
    <div class="container" data-compare-key="footer-1-wrap">
      <footer class="d-flex flex-wrap justify-content-between align-items-center py-3 my-4 border-top" data-compare-key="footer-1">
        <p class="col-md-4 mb-0 text-body-secondary" data-compare-key="footer-1-copy">&copy; 2025 Company, Inc</p>
        <a href="/" class="col-md-4 d-flex align-items-center justify-content-center mb-3 mb-md-0 me-md-auto link-body-emphasis text-decoration-none" data-compare-key="footer-1-brand">
          <span class="fs-5">Brand</span>
        </a>
        <ul class="nav col-md-4 justify-content-end" data-compare-key="footer-1-nav">
          <li class="nav-item"><a href="#" class="nav-link px-2 text-body-secondary">Home</a></li>
          <li class="nav-item"><a href="#" class="nav-link px-2 text-body-secondary">Features</a></li>
          <li class="nav-item"><a href="#" class="nav-link px-2 text-body-secondary">Pricing</a></li>
          <li class="nav-item"><a href="#" class="nav-link px-2 text-body-secondary">FAQs</a></li>
          <li class="nav-item"><a href="#" class="nav-link px-2 text-body-secondary">About</a></li>
        </ul>
      </footer>
    </div>

    <div class="b-example-divider"></div>

    <div class="container" data-compare-key="footer-2-wrap">
      <footer class="d-flex flex-wrap justify-content-between align-items-center py-3 my-4 border-top" data-compare-key="footer-2">
        <div class="col-md-4 d-flex align-items-center" data-compare-key="footer-2-brand">
          <span class="mb-3 mb-md-0 text-body-secondary">&copy; 2025 Company, Inc</span>
        </div>
        <ul class="nav col-md-4 justify-content-end list-unstyled d-flex" data-compare-key="footer-2-social">
          <li class="ms-3"><a class="text-body-secondary" href="#">Tw</a></li>
          <li class="ms-3"><a class="text-body-secondary" href="#">Ig</a></li>
          <li class="ms-3"><a class="text-body-secondary" href="#">Fb</a></li>
        </ul>
      </footer>
    </div>

    <div class="b-example-divider"></div>

    <div class="container" data-compare-key="footer-3-wrap">
      <footer class="py-3 my-4" data-compare-key="footer-3">
        <ul class="nav justify-content-center border-bottom pb-3 mb-3" data-compare-key="footer-3-nav">
          <li class="nav-item"><a href="#" class="nav-link px-2 text-body-secondary">Home</a></li>
          <li class="nav-item"><a href="#" class="nav-link px-2 text-body-secondary">Features</a></li>
          <li class="nav-item"><a href="#" class="nav-link px-2 text-body-secondary">Pricing</a></li>
          <li class="nav-item"><a href="#" class="nav-link px-2 text-body-secondary">FAQs</a></li>
          <li class="nav-item"><a href="#" class="nav-link px-2 text-body-secondary">About</a></li>
        </ul>
        <p class="text-center text-body-secondary" data-compare-key="footer-3-copy">&copy; 2025 Company, Inc</p>
      </footer>
    </div>

    <div class="b-example-divider"></div>

    <div class="container" data-compare-key="footer-4-wrap">
      <footer class="row row-cols-1 row-cols-sm-2 row-cols-md-5 py-5 my-5 border-top" data-compare-key="footer-4">
        <div class="col mb-3" data-compare-key="footer-4-brand">
          <span class="d-flex align-items-center mb-3 link-body-emphasis text-decoration-none fs-5">Brand</span>
          <p class="text-body-secondary">&copy; 2025</p>
        </div>
        <div class="col mb-3"></div>
        <div class="col mb-3" data-compare-key="footer-4-section-1">
          <h5>Section</h5>
          <ul class="nav flex-column">
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Home</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Features</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Pricing</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">FAQs</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">About</a></li>
          </ul>
        </div>
        <div class="col mb-3" data-compare-key="footer-4-section-2">
          <h5>Section</h5>
          <ul class="nav flex-column">
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Home</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Features</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Pricing</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">FAQs</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">About</a></li>
          </ul>
        </div>
        <div class="col mb-3" data-compare-key="footer-4-section-3">
          <h5>Section</h5>
          <ul class="nav flex-column">
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Home</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Features</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Pricing</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">FAQs</a></li>
            <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">About</a></li>
          </ul>
        </div>
      </footer>
    </div>

    <div class="b-example-divider"></div>

    <div class="container" data-compare-key="footer-5-wrap">
      <footer class="py-5" data-compare-key="footer-5">
        <div class="row" data-compare-key="footer-5-row">
          <div class="col-6 col-md-2 mb-3" data-compare-key="footer-5-section-1">
            <h5>Section</h5>
            <ul class="nav flex-column">
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Home</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Features</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Pricing</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">FAQs</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">About</a></li>
            </ul>
          </div>
          <div class="col-6 col-md-2 mb-3" data-compare-key="footer-5-section-2">
            <h5>Section</h5>
            <ul class="nav flex-column">
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Home</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Features</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Pricing</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">FAQs</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">About</a></li>
            </ul>
          </div>
          <div class="col-6 col-md-2 mb-3" data-compare-key="footer-5-section-3">
            <h5>Section</h5>
            <ul class="nav flex-column">
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Home</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Features</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">Pricing</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">FAQs</a></li>
              <li class="nav-item mb-2"><a href="#" class="nav-link p-0 text-body-secondary">About</a></li>
            </ul>
          </div>
          <div class="col-md-5 offset-md-1 mb-3" data-compare-key="footer-5-newsletter">
            <form>
              <h5>Subscribe to our newsletter</h5>
              <p>Monthly digest of what's new and exciting from us.</p>
              <div class="d-flex flex-column flex-sm-row w-100 gap-2" data-compare-key="footer-5-input-row">
                <label for="newsletter1" class="visually-hidden">Email address</label>
                <input id="newsletter1" type="text" class="form-control" placeholder="Email address" data-compare-key="footer-5-input" />
                <bs-button variant="primary" type="button" data-compare-key="footer-5-cta">Subscribe</bs-button>
              </div>
            </form>
          </div>
        </div>

        <div class="d-flex flex-column flex-sm-row justify-content-between py-4 my-4 border-top" data-compare-key="footer-5-bottom">
          <p>&copy; 2025 Company, Inc. All rights reserved.</p>
          <ul class="list-unstyled d-flex" data-compare-key="footer-5-social">
            <li class="ms-3"><a class="link-body-emphasis" href="#" aria-label="Twitter"><span class="d-inline-block bg-secondary rounded" style="width: 24px; height: 24px;"></span></a></li>
            <li class="ms-3"><a class="link-body-emphasis" href="#" aria-label="Instagram"><span class="d-inline-block bg-secondary rounded" style="width: 24px; height: 24px;"></span></a></li>
            <li class="ms-3"><a class="link-body-emphasis" href="#" aria-label="Facebook"><span class="d-inline-block bg-secondary rounded" style="width: 24px; height: 24px;"></span></a></li>
          </ul>
        </div>
      </footer>
    </div>
  </body>
</html>
