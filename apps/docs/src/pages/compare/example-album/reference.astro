---
// Plain Bootstrap reference for the Album example template.
// Mirrors https://getbootstrap.com/docs/5.3/examples/album/ structurally.
// Placeholder thumbnails are inline SVG (no network) so the comparator
// can run deterministically.

const cards = [1, 2, 3, 4, 5, 6, 7, 8, 9];
const cardText =
  'This is a wider card with supporting text below as a natural lead-in to additional content. This content is a little bit longer.';
const placeholderSvg =
  'data:image/svg+xml;utf8,' +
  encodeURIComponent(
    '<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="225" preserveAspectRatio="xMidYMid slice" focusable="false" role="img" viewBox="0 0 318 225"><rect width="100%" height="100%" fill="#55595c"/><text x="50%" y="50%" fill="#eceeef" dy=".3em" text-anchor="middle" font-family="system-ui,sans-serif" font-size="18">Thumbnail</text></svg>',
  );
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Album reference</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
    </style>
  </head>
  <body>
    <header data-bs-theme="dark" data-compare-key="page-header">
      <div class="navbar navbar-dark bg-dark shadow-sm" data-compare-key="navbar">
        <div class="container">
          <a href="#" class="navbar-brand d-flex align-items-center" data-compare-key="navbar-brand">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" aria-hidden="true" class="me-2" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            <strong data-compare-key="navbar-brand-text">Album</strong>
          </a>
        </div>
      </div>
    </header>

    <main>
      <section class="py-5 text-center container" data-compare-key="hero">
        <div class="row py-lg-5">
          <div class="col-lg-6 col-md-8 mx-auto">
            <h1 class="fw-light" data-compare-key="hero-title">Album example</h1>
            <p class="lead text-body-secondary" data-compare-key="hero-lead">
              Something short and leading about the collection below—its contents,
              the creator, etc. Make it short and sweet, but not too short so
              folks don't simply skip over it entirely.
            </p>
            <p data-compare-key="hero-actions">
              <a href="#" class="btn btn-primary my-2" data-compare-key="hero-cta-primary">Main call to action</a>
              <a href="#" class="btn btn-secondary my-2" data-compare-key="hero-cta-secondary">Secondary action</a>
            </p>
          </div>
        </div>
      </section>

      <div class="album py-5 bg-body-tertiary" data-compare-key="album">
        <div class="container">
          <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3" data-compare-key="album-grid">
            {cards.map((n) => (
              <div class="col" data-compare-key={`cell-${n}`}>
                <div class="card shadow-sm" data-compare-key={`card-${n}`}>
                  <img src={placeholderSvg} alt="Thumbnail" class="card-img-top" data-compare-key={`card-${n}-img`} />
                  <div class="card-body" data-compare-key={`card-${n}-body`}>
                    <p class="card-text" data-compare-key={`card-${n}-text`}>{cardText}</p>
                    <div class="d-flex justify-content-between align-items-center" data-compare-key={`card-${n}-actions`}>
                      <div class="btn-group" data-compare-key={`card-${n}-btngroup`}>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-compare-key={`card-${n}-view`}>View</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-compare-key={`card-${n}-edit`}>Edit</button>
                      </div>
                      <small class="text-body-secondary" data-compare-key={`card-${n}-meta`}>9 mins</small>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </main>

    <footer class="text-body-secondary py-5" data-compare-key="footer">
      <div class="container">
        <p class="float-end mb-1" data-compare-key="footer-back">
          <a href="#">Back to top</a>
        </p>
        <p class="mb-1" data-compare-key="footer-line-1">Album example is &copy; Bootstrap, but please download and customize it for yourself!</p>
        <p class="mb-0" data-compare-key="footer-line-2">New to Bootstrap? <a href="/">Visit the homepage</a> or read our <a href="#">getting started guide</a>.</p>
      </div>
    </footer>
  </body>
</html>
