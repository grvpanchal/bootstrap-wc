---
// Plain Bootstrap reference for the Sticky-footer example template.
// Mirrors https://getbootstrap.com/docs/5.3/examples/sticky-footer/.
---

<!doctype html>
<html lang="en" class="h-100" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sticky footer reference</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .container {
        width: auto;
        max-width: 680px;
        padding: 0 15px;
      }
    </style>
  </head>
  <body class="d-flex flex-column h-100">
    <main class="flex-shrink-0" data-compare-key="sticky-main">
      <div class="container" data-compare-key="sticky-main-container">
        <h1 class="mt-5" data-compare-key="sticky-main-title">Sticky footer</h1>
        <p class="lead" data-compare-key="sticky-main-lead">Pin a footer to the bottom of the viewport in desktop browsers with this custom HTML and CSS.</p>
        <p data-compare-key="sticky-main-text">Use <a href="/examples/sticky-footer-navbar/" data-compare-key="sticky-main-link">the sticky footer with a fixed navbar</a> if need be, too.</p>
      </div>
    </main>
    <footer class="footer mt-auto py-3 bg-body-tertiary" data-compare-key="sticky-footer">
      <div class="container" data-compare-key="sticky-footer-container">
        <span class="text-body-secondary" data-compare-key="sticky-footer-text">Place sticky footer content here.</span>
      </div>
    </footer>
  </body>
</html>
