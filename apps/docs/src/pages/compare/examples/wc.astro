---
// `<bs-*>` port of ./reference.astro for the Examples landing page.
// Same DOM shape, same data-compare-key annotations; <bs-card> replaces
// the plain `.card` wrappers. `no-body` keeps the inner `.card-body`
// element in light DOM so the comparator can tag it with a key.

const PREVIEW_BASE = 'https://getbootstrap.com/docs/5.3/examples';

const customComponents = [
  { slug: 'album', title: 'Album', desc: 'Simple one-page template for photo galleries and portfolios.' },
  { slug: 'pricing', title: 'Pricing', desc: 'Pricing page built with cards and a custom header and footer.' },
  { slug: 'checkout', title: 'Checkout', desc: 'Custom checkout form showing form components and validation.' },
  { slug: 'product', title: 'Product', desc: 'Lean product-focused marketing page with grid and image work.' },
];

const snippets = [
  { slug: 'headers', title: 'Headers', desc: 'Display branding, navigation, search, and more.' },
  { slug: 'heroes', title: 'Heroes', desc: 'Set the stage on your homepage with a clear call to action.' },
  { slug: 'features', title: 'Features', desc: 'Explain features, benefits, or other marketing details.' },
  { slug: 'footers', title: 'Footers', desc: 'Finish every page strong with a footer, big or small.' },
];

const navbars = [
  { slug: 'navbars', title: 'Navbars', desc: 'Demonstration of all responsive and container options.' },
  { slug: 'navbars-offcanvas', title: 'Navbars offcanvas', desc: 'Same as Navbars, but with the offcanvas component.' },
  { slug: 'navbar-static', title: 'Navbar static', desc: 'Static top navbar with some additional content.' },
  { slug: 'navbar-fixed', title: 'Navbar fixed', desc: 'Fixed top navbar with some additional content.' },
];
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Examples wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
    </style>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body>
    <div class="container py-5">
      <header class="pb-4 border-bottom mb-5" data-compare-key="hero">
        <h1 class="display-5 fw-bold mb-3" data-compare-key="hero-title">Examples</h1>
        <p class="lead text-body-secondary mb-0" data-compare-key="hero-lead">
          Quickly get a project started with any of our examples ranging from
          using parts of the framework to custom components and layouts.
        </p>
      </header>

      <section class="mb-5">
        <h2 class="pb-2 mb-3" data-compare-key="section-custom-title">Custom components</h2>
        <p class="text-body-secondary mb-4" data-compare-key="section-custom-lead">
          Polished, production-quality templates for common page types.
        </p>
        <div class="row g-4">
          {customComponents.map((ex) => (
            <div class="col-sm-6 col-md-3" data-compare-key={`cell-${ex.slug}`}>
              <bs-card no-body class="h-100 shadow-sm" data-compare-key={`card-${ex.slug}`}>
                <img
                  slot="image"
                  src={`${PREVIEW_BASE}/${ex.slug}/preview.png`}
                  alt={`${ex.title} example preview`}
                  class="card-img-top"
                  loading="lazy"
                  data-compare-key={`thumb-${ex.slug}`}
                />
                <div class="card-body" data-compare-key={`body-${ex.slug}`}>
                  <h3 class="card-title h6 mb-1" data-compare-key={`title-${ex.slug}`}>{ex.title}</h3>
                  <p class="card-text small text-body-secondary mb-0" data-compare-key={`desc-${ex.slug}`}>{ex.desc}</p>
                </div>
              </bs-card>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-5">
        <h2 class="pb-2 mb-3" data-compare-key="section-snippets-title">Snippets</h2>
        <p class="text-body-secondary mb-4" data-compare-key="section-snippets-lead">
          Drop-in pieces for common page sections.
        </p>
        <div class="row g-4">
          {snippets.map((ex) => (
            <div class="col-sm-6 col-md-3" data-compare-key={`cell-${ex.slug}`}>
              <bs-card no-body class="h-100 shadow-sm" data-compare-key={`card-${ex.slug}`}>
                <img
                  slot="image"
                  src={`${PREVIEW_BASE}/${ex.slug}/preview.png`}
                  alt={`${ex.title} example preview`}
                  class="card-img-top"
                  loading="lazy"
                  data-compare-key={`thumb-${ex.slug}`}
                />
                <div class="card-body" data-compare-key={`body-${ex.slug}`}>
                  <h3 class="card-title h6 mb-1" data-compare-key={`title-${ex.slug}`}>{ex.title}</h3>
                  <p class="card-text small text-body-secondary mb-0" data-compare-key={`desc-${ex.slug}`}>{ex.desc}</p>
                </div>
              </bs-card>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-5">
        <h2 class="pb-2 mb-3" data-compare-key="section-navbars-title">Navbars</h2>
        <p class="text-body-secondary mb-4" data-compare-key="section-navbars-lead">
          Layouts and configurations of the navbar component.
        </p>
        <div class="row g-4">
          {navbars.map((ex) => (
            <div class="col-sm-6 col-md-3" data-compare-key={`cell-${ex.slug}`}>
              <bs-card no-body class="h-100 shadow-sm" data-compare-key={`card-${ex.slug}`}>
                <img
                  slot="image"
                  src={`${PREVIEW_BASE}/${ex.slug}/preview.png`}
                  alt={`${ex.title} example preview`}
                  class="card-img-top"
                  loading="lazy"
                  data-compare-key={`thumb-${ex.slug}`}
                />
                <div class="card-body" data-compare-key={`body-${ex.slug}`}>
                  <h3 class="card-title h6 mb-1" data-compare-key={`title-${ex.slug}`}>{ex.title}</h3>
                  <p class="card-text small text-body-secondary mb-0" data-compare-key={`desc-${ex.slug}`}>{ex.desc}</p>
                </div>
              </bs-card>
            </div>
          ))}
        </div>
      </section>
    </div>
  </body>
</html>
