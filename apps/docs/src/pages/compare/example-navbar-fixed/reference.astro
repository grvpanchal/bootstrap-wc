---
// Plain Bootstrap reference for the Navbar Fixed example template.
// Mirrors https://getbootstrap.com/docs/5.3/examples/navbar-fixed/.
// `padding-top` on body absorbs the fixed navbar height, matching
// Bootstrap's recommended treatment for fixed-top navbars.
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Navbar fixed reference</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
        padding-top: 4.5rem;
        min-height: 75rem;
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </head>
  <body data-compare-key="root">
    <nav class="navbar navbar-expand-md navbar-dark fixed-top bg-dark" data-compare-key="navbar">
      <div class="container-fluid">
        <a class="navbar-brand" href="#" data-compare-key="navbar-brand">Fixed navbar</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation" data-compare-key="navbar-toggler">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarCollapse" data-compare-key="navbar-collapse">
          <ul class="navbar-nav me-auto mb-2 mb-md-0" data-compare-key="navbar-nav">
            <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
            <li class="nav-item"><a class="nav-link disabled" aria-disabled="true">Disabled</a></li>
          </ul>
          <form class="d-flex" role="search" data-compare-key="navbar-form">
            <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
            <button class="btn btn-outline-success" type="submit" data-compare-key="navbar-form-submit">Search</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container">
      <div class="bg-body-tertiary p-5 rounded" data-compare-key="hero">
        <h1 data-compare-key="hero-title">Navbar example</h1>
        <p class="lead" data-compare-key="hero-lead">This example is a quick exercise to illustrate how fixed to top navbar works. As you scroll, it will remain fixed to the top of your browser's viewport.</p>
        <a class="btn btn-lg btn-primary" href="#" role="button" data-compare-key="hero-cta">View navbar docs &raquo;</a>
      </div>
    </main>
  </body>
</html>
