---
// Plain Bootstrap reference for the Checkout example template.
// Mirrors https://getbootstrap.com/docs/5.3/examples/checkout/ structurally.
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Checkout reference</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
    </style>
  </head>
  <body class="bg-body-tertiary">
    <div class="container" data-compare-key="root">
      <main>
        <div class="py-5 text-center" data-compare-key="hero">
          <svg xmlns="http://www.w3.org/2000/svg" class="d-block mx-auto mb-4" width="72" height="57" viewBox="0 0 118 94" role="img" data-compare-key="hero-logo"><title>Bootstrap</title><path fill-rule="evenodd" clip-rule="evenodd" d="M24.509 0c-6.733 0-11.715 5.893-11.492 12.284.214 6.14-.064 14.092-2.066 20.577C8.943 39.365 5.547 43.485 0 44.014v5.972c5.547.529 8.943 4.649 10.951 11.153 2.002 6.485 2.28 14.437 2.066 20.577C12.794 88.106 17.776 94 24.51 94H93.5c6.733 0 11.714-5.893 11.491-12.284-.214-6.14.064-14.092 2.066-20.577 2.009-6.504 5.396-10.624 10.943-11.153v-5.972c-5.547-.529-8.934-4.649-10.943-11.153-2.002-6.484-2.28-14.437-2.066-20.577C105.214 5.894 100.233 0 93.5 0H24.508zM80 57.863C80 66.663 73.436 72 62.543 72H44a2 2 0 01-2-2V24a2 2 0 012-2h18.437c9.083 0 15.044 4.92 15.044 12.474 0 5.302-4.01 10.049-9.119 10.88v.277C75.317 46.394 80 51.21 80 57.863zM60.521 28.34H49.948v14.934h8.905c6.884 0 10.68-2.772 10.68-7.727 0-4.643-3.264-7.207-9.012-7.207zM49.948 49.2v16.458H60.91c7.167 0 10.964-2.876 10.964-8.281 0-5.406-3.903-8.178-11.425-8.178H49.948z" fill="currentColor"></path></svg>
          <h1 class="h2" data-compare-key="hero-title">Checkout form</h1>
          <p class="lead" data-compare-key="hero-lead">Below is an example form built entirely with Bootstrap's form controls. Each required form group has a validation state that can be triggered by attempting to submit the form without completing it.</p>
        </div>

        <div class="row g-5" data-compare-key="layout-row">
          <div class="col-md-5 col-lg-4 order-md-last" data-compare-key="cart-col">
            <h4 class="d-flex justify-content-between align-items-center mb-3" data-compare-key="cart-heading">
              <span class="text-primary">Your cart</span>
              <span class="badge bg-primary rounded-pill" data-compare-key="cart-count">3</span>
            </h4>
            <ul class="list-group mb-3" data-compare-key="cart-list">
              <li class="list-group-item d-flex justify-content-between lh-sm" data-compare-key="cart-item-1">
                <div>
                  <h6 class="my-0">Product name</h6>
                  <small class="text-body-secondary">Brief description</small>
                </div>
                <span class="text-body-secondary">$12</span>
              </li>
              <li class="list-group-item d-flex justify-content-between lh-sm" data-compare-key="cart-item-2">
                <div>
                  <h6 class="my-0">Second product</h6>
                  <small class="text-body-secondary">Brief description</small>
                </div>
                <span class="text-body-secondary">$8</span>
              </li>
              <li class="list-group-item d-flex justify-content-between lh-sm" data-compare-key="cart-item-3">
                <div>
                  <h6 class="my-0">Third item</h6>
                  <small class="text-body-secondary">Brief description</small>
                </div>
                <span class="text-body-secondary">$5</span>
              </li>
              <li class="list-group-item d-flex justify-content-between bg-body-tertiary" data-compare-key="cart-promo">
                <div class="text-success">
                  <h6 class="my-0">Promo code</h6>
                  <small>EXAMPLECODE</small>
                </div>
                <span class="text-success">−$5</span>
              </li>
              <li class="list-group-item d-flex justify-content-between" data-compare-key="cart-total">
                <span>Total (USD)</span>
                <strong>$20</strong>
              </li>
            </ul>

            <form class="card p-2" data-compare-key="promo-form">
              <div class="input-group" data-compare-key="promo-input-group">
                <input type="text" class="form-control" placeholder="Promo code" aria-label="Promo code" data-compare-key="promo-input" />
                <button type="submit" class="btn btn-secondary" data-compare-key="promo-submit">Redeem</button>
              </div>
            </form>
          </div>

          <div class="col-md-7 col-lg-8" data-compare-key="form-col">
            <h4 class="mb-3" data-compare-key="billing-heading">Billing address</h4>
            <form class="needs-validation" novalidate data-compare-key="billing-form">
              <div class="row g-3" data-compare-key="billing-row">
                <div class="col-sm-6" data-compare-key="field-firstname">
                  <label for="firstName" class="form-label">First name</label>
                  <input type="text" class="form-control" id="firstName" required />
                </div>
                <div class="col-sm-6" data-compare-key="field-lastname">
                  <label for="lastName" class="form-label">Last name</label>
                  <input type="text" class="form-control" id="lastName" required />
                </div>
                <div class="col-12" data-compare-key="field-username">
                  <label for="username" class="form-label">Username</label>
                  <div class="input-group has-validation">
                    <span class="input-group-text">@</span>
                    <input type="text" class="form-control" id="username" required />
                  </div>
                </div>
                <div class="col-12" data-compare-key="field-email">
                  <label for="email" class="form-label">Email <span class="text-body-secondary">(Optional)</span></label>
                  <input type="email" class="form-control" id="email" />
                </div>
                <div class="col-12" data-compare-key="field-address">
                  <label for="address" class="form-label">Address</label>
                  <input type="text" class="form-control" id="address" placeholder="1234 Main St" required />
                </div>
                <div class="col-12" data-compare-key="field-address2">
                  <label for="address2" class="form-label">Address 2 <span class="text-body-secondary">(Optional)</span></label>
                  <input type="text" class="form-control" id="address2" placeholder="Apartment or suite" />
                </div>
                <div class="col-md-5" data-compare-key="field-country">
                  <label for="country" class="form-label">Country</label>
                  <select class="form-select" id="country" required>
                    <option value="">Choose...</option>
                    <option>United States</option>
                  </select>
                </div>
                <div class="col-md-4" data-compare-key="field-state">
                  <label for="state" class="form-label">State</label>
                  <select class="form-select" id="state" required>
                    <option value="">Choose...</option>
                    <option>California</option>
                  </select>
                </div>
                <div class="col-md-3" data-compare-key="field-zip">
                  <label for="zip" class="form-label">Zip</label>
                  <input type="text" class="form-control" id="zip" required />
                </div>
              </div>

              <hr class="my-4" />

              <div class="form-check" data-compare-key="check-same">
                <input class="form-check-input" type="checkbox" id="same-address" />
                <label class="form-check-label" for="same-address">Shipping address is the same as my billing address</label>
              </div>

              <div class="form-check" data-compare-key="check-save">
                <input class="form-check-input" type="checkbox" id="save-info" />
                <label class="form-check-label" for="save-info">Save this information for next time</label>
              </div>

              <hr class="my-4" />

              <h4 class="mb-3" data-compare-key="payment-heading">Payment</h4>

              <div class="my-3" data-compare-key="payment-radios">
                <div class="form-check" data-compare-key="radio-credit">
                  <input class="form-check-input" type="radio" name="paymentMethod" id="credit" value="credit" checked />
                  <label class="form-check-label" for="credit">Credit card</label>
                </div>
                <div class="form-check" data-compare-key="radio-debit">
                  <input class="form-check-input" type="radio" name="paymentMethod" id="debit" value="debit" />
                  <label class="form-check-label" for="debit">Debit card</label>
                </div>
                <div class="form-check" data-compare-key="radio-paypal">
                  <input class="form-check-input" type="radio" name="paymentMethod" id="paypal" value="paypal" />
                  <label class="form-check-label" for="paypal">PayPal</label>
                </div>
              </div>

              <div class="row gy-3" data-compare-key="cc-row">
                <div class="col-md-6" data-compare-key="field-cc-name">
                  <label for="cc-name" class="form-label">Name on card</label>
                  <input type="text" class="form-control" id="cc-name" required />
                  <small class="text-body-secondary">Full name as displayed on card</small>
                </div>
                <div class="col-md-6" data-compare-key="field-cc-number">
                  <label for="cc-number" class="form-label">Credit card number</label>
                  <input type="text" class="form-control" id="cc-number" required />
                </div>
                <div class="col-md-3" data-compare-key="field-cc-expiration">
                  <label for="cc-expiration" class="form-label">Expiration</label>
                  <input type="text" class="form-control" id="cc-expiration" required />
                </div>
                <div class="col-md-3" data-compare-key="field-cc-cvv">
                  <label for="cc-cvv" class="form-label">CVV</label>
                  <input type="text" class="form-control" id="cc-cvv" required />
                </div>
              </div>

              <hr class="my-4" />

              <button class="w-100 btn btn-primary btn-lg" type="submit" data-compare-key="submit-cta">Continue to checkout</button>
            </form>
          </div>
        </div>
      </main>

      <footer class="my-5 pt-5 text-body-secondary text-center text-small" data-compare-key="footer">
        <p class="mb-1">&copy; 2017–2025 Company Name</p>
        <ul class="list-unstyled" data-compare-key="footer-links">
          <li><a href="#">Privacy</a></li>
          <li><a href="#">Terms</a></li>
          <li><a href="#">Support</a></li>
        </ul>
      </footer>
    </div>
  </body>
</html>
