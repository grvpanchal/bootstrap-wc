---
// `<bs-*>` port of ./reference.astro for the Jumbotrons (plural) snippet
// page. Only the call-to-action / secondary link <button class="btn">s
// are swapped for <bs-button>; the .btn-close stays native (its host
// shape would change with <bs-close-button>).
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Jumbotrons wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .b-example-divider {
        width: 100%;
        height: 3rem;
        background-color: rgba(0, 0, 0, 0.1);
        border: solid rgba(0, 0, 0, 0.15);
        border-width: 1px 0;
        box-shadow:
          inset 0 0.5em 1.5em rgba(0, 0, 0, 0.1),
          inset 0 0.125em 0.5em rgba(0, 0, 0, 0.15);
      }
      .border-dashed {
        border-style: dashed !important;
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body data-compare-key="root">
    <div class="container my-5" data-compare-key="row-icon-wrap">
      <div class="p-5 text-center bg-body-tertiary rounded-3" data-compare-key="row-icon">
        <h1 class="text-body-emphasis" data-compare-key="row-icon-title">Jumbotron with icon</h1>
        <p class="col-lg-8 mx-auto fs-5 text-muted" data-compare-key="row-icon-lead">
          This is a custom jumbotron featuring an SVG image at the top, some longer text that wraps early thanks to a responsive <code>.col-*</code> class, and a customized call to action.
        </p>
        <div class="d-inline-flex gap-2 mb-5" data-compare-key="row-icon-actions">
          <bs-button variant="primary" size="lg" class="d-inline-flex align-items-center px-4 rounded-pill" data-compare-key="row-icon-cta">Call to action</bs-button>
          <bs-button variant="secondary" button-style="outline" size="lg" class="px-4 rounded-pill" data-compare-key="row-icon-secondary">Secondary link</bs-button>
        </div>
      </div>
    </div>
    <div class="b-example-divider"></div>

    <div class="container my-5" data-compare-key="row-placeholder-wrap">
      <div class="position-relative p-5 text-center text-muted bg-body border border-dashed rounded-5" data-compare-key="row-placeholder">
        <button type="button" class="position-absolute top-0 end-0 p-3 m-3 btn-close bg-secondary bg-opacity-10 rounded-pill" aria-label="Close"></button>
        <h1 class="text-body-emphasis" data-compare-key="row-placeholder-title">Placeholder jumbotron</h1>
        <p class="col-lg-6 mx-auto mb-4" data-compare-key="row-placeholder-lead">
          This faded back jumbotron is useful for placeholder content. It's also a great way to add a bit of context to a page or section when no content is available and to encourage visitors to take a specific action.
        </p>
        <bs-button variant="primary" class="px-5 mb-5" data-compare-key="row-placeholder-cta">Call to action</bs-button>
      </div>
    </div>
    <div class="b-example-divider"></div>

    <div class="my-5" data-compare-key="row-full-wrap">
      <div class="p-5 text-center bg-body-tertiary" data-compare-key="row-full">
        <div class="container py-5">
          <h1 class="text-body-emphasis" data-compare-key="row-full-title">Full-width jumbotron</h1>
          <p class="col-lg-8 mx-auto lead" data-compare-key="row-full-lead">
            This takes the basic jumbotron above and makes its background edge-to-edge with a <code>.container</code> inside to align content. Similar to above, it's been recreated with built-in grid and utility classes.
          </p>
        </div>
      </div>
    </div>
    <div class="b-example-divider"></div>

    <div class="container my-5" data-compare-key="row-basic-wrap">
      <div class="p-5 text-center bg-body-tertiary rounded-3" data-compare-key="row-basic">
        <h1 class="text-body-emphasis" data-compare-key="row-basic-title">Basic jumbotron</h1>
        <p class="lead" data-compare-key="row-basic-lead">
          This is a simple Bootstrap jumbotron that sits within a <code>.container</code>, recreated with built-in utility classes.
        </p>
      </div>
    </div>
    <div class="b-example-divider"></div>
  </body>
</html>
