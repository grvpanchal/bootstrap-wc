---
// `<bs-*>` port of ./reference.astro for the Modals snippet page.
// Uses <bs-modal static-display modal-class content-class header-class
// body-class footer-class heading="..."> for both open-modal-shell variants.
// static-display turns on .modal.position-static.d-block (no backdrop, no
// focus trap, no portal). The new *-class attributes thread Bootstrap
// utility classes onto the inner .modal/.modal-content/.modal-header/
// .modal-body/.modal-footer divs so the modal-sheet / choice patterns
// render exactly like the reference.
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Modals wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .b-example-divider {
        width: 100%;
        height: 3rem;
        background-color: rgba(0, 0, 0, 0.1);
        border: solid rgba(0, 0, 0, 0.15);
        border-width: 1px 0;
        box-shadow:
          inset 0 0.5em 1.5em rgba(0, 0, 0, 0.1),
          inset 0 0.125em 0.5em rgba(0, 0, 0, 0.15);
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body data-compare-key="root">
    <bs-modal
      static-display
      heading="Modal title"
      modal-class="modal-sheet bg-body-secondary p-4 py-md-5"
      content-class="rounded-4 shadow"
      header-class="border-bottom-0"
      body-class="py-0"
      footer-class="flex-column align-items-stretch w-100 gap-2 pb-3 border-top-0"
      id="modalSheet"
      data-compare-key="modal-sheet"
    >
      <p data-compare-key="modal-sheet-body">This is a modal sheet, a variation of the modal that docks itself to the bottom of the viewport like the newer share sheets in iOS.</p>
      <bs-button slot="footer" variant="primary" size="lg" data-compare-key="modal-sheet-save">Save changes</bs-button>
      <bs-button slot="footer" variant="secondary" size="lg" data-bs-dismiss="modal" data-compare-key="modal-sheet-close">Close</bs-button>
    </bs-modal>
    <div class="b-example-divider"></div>

    <bs-modal
      static-display
      no-close-button
      modal-class="modal-sheet bg-body-secondary p-4 py-md-5"
      content-class="rounded-3 shadow"
      body-class="p-4 text-center"
      footer-class="flex-nowrap p-0"
      id="modalChoice"
      data-compare-key="modal-choice"
    >
      <h5 class="mb-0" data-compare-key="modal-choice-title">Enable this setting?</h5>
      <p class="mb-0" data-compare-key="modal-choice-body">You can always change your mind in your account settings.</p>
      <bs-button slot="footer" button-style="link" size="lg" class="fs-6 text-decoration-none col-6 py-3 m-0 rounded-0 border-end" data-compare-key="modal-choice-yes"><strong>Yes, enable</strong></bs-button>
      <bs-button slot="footer" button-style="link" size="lg" class="fs-6 text-decoration-none col-6 py-3 m-0 rounded-0" data-bs-dismiss="modal" data-compare-key="modal-choice-no">No thanks</bs-button>
    </bs-modal>
    <div class="b-example-divider"></div>
  </body>
</html>
