---
// `<bs-*>` port of ./reference.astro for the Modals snippet page.
// The upstream variants are open modal shells in static position
// (modal-sheet style). <bs-modal> renders a managed open/close modal
// with backdrop — its host shape doesn't match the static modal-sheet
// pattern. We keep native .modal markup and swap the buttons for
// <bs-button>.
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Modals wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .b-example-divider {
        width: 100%;
        height: 3rem;
        background-color: rgba(0, 0, 0, 0.1);
        border: solid rgba(0, 0, 0, 0.15);
        border-width: 1px 0;
        box-shadow:
          inset 0 0.5em 1.5em rgba(0, 0, 0, 0.1),
          inset 0 0.125em 0.5em rgba(0, 0, 0, 0.15);
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body data-compare-key="root">
    <div class="modal modal-sheet position-static d-block bg-body-secondary p-4 py-md-5" tabindex="-1" role="dialog" id="modalSheet" data-compare-key="modal-sheet">
      <div class="modal-dialog">
        <div class="modal-content rounded-4 shadow">
          <div class="modal-header border-bottom-0">
            <h1 class="modal-title fs-5" data-compare-key="modal-sheet-title">Modal title</h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body py-0">
            <p data-compare-key="modal-sheet-body">This is a modal sheet, a variation of the modal that docks itself to the bottom of the viewport like the newer share sheets in iOS.</p>
          </div>
          <div class="modal-footer flex-column align-items-stretch w-100 gap-2 pb-3 border-top-0" data-compare-key="modal-sheet-footer">
            <bs-button variant="primary" size="lg" data-compare-key="modal-sheet-save">Save changes</bs-button>
            <bs-button variant="secondary" size="lg" data-bs-dismiss="modal" data-compare-key="modal-sheet-close">Close</bs-button>
          </div>
        </div>
      </div>
    </div>
    <div class="b-example-divider"></div>

    <div class="modal modal-sheet position-static d-block bg-body-secondary p-4 py-md-5" tabindex="-1" role="dialog" id="modalChoice" data-compare-key="modal-choice">
      <div class="modal-dialog">
        <div class="modal-content rounded-3 shadow">
          <div class="modal-body p-4 text-center">
            <h5 class="mb-0" data-compare-key="modal-choice-title">Enable this setting?</h5>
            <p class="mb-0" data-compare-key="modal-choice-body">You can always change your mind in your account settings.</p>
          </div>
          <div class="modal-footer flex-nowrap p-0" data-compare-key="modal-choice-footer">
            <bs-button variant="link" size="lg" class="fs-6 text-decoration-none col-6 py-3 m-0 rounded-0 border-end" data-compare-key="modal-choice-yes"><strong>Yes, enable</strong></bs-button>
            <bs-button variant="link" size="lg" class="fs-6 text-decoration-none col-6 py-3 m-0 rounded-0" data-bs-dismiss="modal" data-compare-key="modal-choice-no">No thanks</bs-button>
          </div>
        </div>
      </div>
    </div>
    <div class="b-example-divider"></div>
  </body>
</html>
