---
// `<bs-*>` port of ./reference.astro for the Dropdowns snippet page.
// Uses the new <bs-dropdown-menu> shell component (host = .dropdown-menu
// .show .position-static, no toggle / JS lifecycle) so authors can drop
// open menus in any context — the search-filterable variant slots a
// non-list <form> + <ul> directly because <bs-dropdown-menu> doesn't
// require <li> children.
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dropdowns wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      import('@bootstrap-wc/components');
    </script>
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .b-example-divider {
        width: 100%;
        height: 3rem;
        background-color: rgba(0, 0, 0, 0.1);
        border: solid rgba(0, 0, 0, 0.15);
        border-width: 1px 0;
        box-shadow:
          inset 0 0.5em 1.5em rgba(0, 0, 0, 0.1),
          inset 0 0.125em 0.5em rgba(0, 0, 0, 0.15);
      }
      .w-220px {
        width: 220px;
      }
      .w-280px {
        width: 280px;
      }
    </style>
  </head>
  <body data-compare-key="root">
    <div class="d-flex flex-column flex-md-row p-4 gap-4 py-md-5 align-items-center justify-content-center" data-compare-key="row-basic">
      <bs-dropdown-menu class="d-grid gap-1 p-2 rounded-3 mx-0 shadow w-220px" data-bs-theme="light" data-compare-key="menu-basic-light">
        <li><a class="dropdown-item rounded-2 active" href="#">Action</a></li>
        <li><a class="dropdown-item rounded-2" href="#">Another action</a></li>
        <li><a class="dropdown-item rounded-2" href="#">Something else here</a></li>
        <li><hr class="dropdown-divider" /></li>
        <li><a class="dropdown-item rounded-2" href="#">Separated link</a></li>
      </bs-dropdown-menu>
      <bs-dropdown-menu class="d-grid gap-1 p-2 rounded-3 mx-0 border-0 shadow w-220px" data-bs-theme="dark" data-compare-key="menu-basic-dark">
        <li><a class="dropdown-item rounded-2 active" href="#">Action</a></li>
        <li><a class="dropdown-item rounded-2" href="#">Another action</a></li>
        <li><a class="dropdown-item rounded-2" href="#">Something else here</a></li>
        <li><hr class="dropdown-divider" /></li>
        <li><a class="dropdown-item rounded-2" href="#">Separated link</a></li>
      </bs-dropdown-menu>
    </div>
    <div class="b-example-divider"></div>

    <div class="d-flex flex-column flex-md-row p-4 gap-4 py-md-5 align-items-center justify-content-center" data-compare-key="row-search">
      <bs-dropdown-menu display-block class="pt-0 mx-0 rounded-3 shadow overflow-hidden w-280px" data-bs-theme="light" data-compare-key="menu-search-light">
        <form class="p-2 mb-2 bg-body-tertiary border-bottom">
          <input type="search" class="form-control" autocomplete="off" placeholder="Type to filter..." />
        </form>
        <ul class="list-unstyled mb-0">
          <li><a class="dropdown-item d-flex align-items-center gap-2 py-2" href="#"><span class="d-inline-block bg-success rounded-circle p-1"></span>Action</a></li>
          <li><a class="dropdown-item d-flex align-items-center gap-2 py-2" href="#"><span class="d-inline-block bg-primary rounded-circle p-1"></span>Another action</a></li>
          <li><a class="dropdown-item d-flex align-items-center gap-2 py-2" href="#"><span class="d-inline-block bg-danger rounded-circle p-1"></span>Something else here</a></li>
          <li><a class="dropdown-item d-flex align-items-center gap-2 py-2" href="#"><span class="d-inline-block bg-info rounded-circle p-1"></span>Separated link</a></li>
        </ul>
      </bs-dropdown-menu>
      <bs-dropdown-menu display-block class="border-0 pt-0 mx-0 rounded-3 shadow overflow-hidden w-280px" data-bs-theme="dark" data-compare-key="menu-search-dark">
        <form class="p-2 mb-2 bg-dark border-bottom border-dark">
          <input type="search" class="form-control bg-dark" autocomplete="off" placeholder="Type to filter..." />
        </form>
        <ul class="list-unstyled mb-0">
          <li><a class="dropdown-item d-flex align-items-center gap-2 py-2" href="#"><span class="d-inline-block bg-success rounded-circle p-1"></span>Action</a></li>
          <li><a class="dropdown-item d-flex align-items-center gap-2 py-2" href="#"><span class="d-inline-block bg-primary rounded-circle p-1"></span>Another action</a></li>
          <li><a class="dropdown-item d-flex align-items-center gap-2 py-2" href="#"><span class="d-inline-block bg-danger rounded-circle p-1"></span>Something else here</a></li>
          <li><a class="dropdown-item d-flex align-items-center gap-2 py-2" href="#"><span class="d-inline-block bg-info rounded-circle p-1"></span>Separated link</a></li>
        </ul>
      </bs-dropdown-menu>
    </div>
    <div class="b-example-divider"></div>
  </body>
</html>
