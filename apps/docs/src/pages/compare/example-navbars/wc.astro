---
// `<bs-*>` port of ./reference.astro for the Navbars example template.
// bs-navbar provides the .navbar chrome on the host; toggler /
// collapse / nav-items are native markup with bs-nav + bs-nav-item
// for the items themselves. Bootstrap's bundle JS handles the
// toggle animation.
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Navbars wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
        padding-bottom: 20px;
      }
      bs-navbar {
        margin-bottom: 20px;
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body data-compare-key="root">
    <main>
      <!-- 1. Never expand (always collapsed) -->
      <bs-navbar expand="never" theme="dark" background="dark" container="fluid" aria-label="First navbar example" data-compare-key="nav-1">
        <a class="navbar-brand" href="#">Never expand</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-1-collapse" aria-controls="nav-1-collapse" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav-1-collapse">
          <bs-nav class="me-auto mb-2" data-compare-key="nav-1-nav">
            <bs-nav-item href="#" active>Home</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
            <bs-nav-item disabled>Disabled</bs-nav-item>
          </bs-nav>
          <form class="d-flex" role="search" data-compare-key="nav-1-form">
            <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
            <bs-button variant="success" button-style="outline" type="submit" data-compare-key="nav-1-submit">Search</bs-button>
          </form>
        </div>
      </bs-navbar>

      <!-- 2. Always expand -->
      <bs-navbar expand="always" theme="dark" background="dark" container="fluid" aria-label="Second navbar example" data-compare-key="nav-2">
        <a class="navbar-brand" href="#">Always expand</a>
        <bs-nav class="me-auto" data-compare-key="nav-2-nav">
          <bs-nav-item href="#" active>Home</bs-nav-item>
          <bs-nav-item href="#">Link</bs-nav-item>
        </bs-nav>
        <form role="search" data-compare-key="nav-2-form">
          <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
        </form>
      </bs-navbar>

      <!-- 3. Expand at sm -->
      <bs-navbar expand="sm" theme="dark" background="dark" container="fluid" aria-label="Third navbar example" data-compare-key="nav-3">
        <a class="navbar-brand" href="#">Expand at sm</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-3-collapse" aria-controls="nav-3-collapse" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav-3-collapse">
          <bs-nav class="me-auto mb-2 mb-sm-0" data-compare-key="nav-3-nav">
            <bs-nav-item href="#" active>Home</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
            <bs-nav-item disabled>Disabled</bs-nav-item>
          </bs-nav>
          <form role="search" data-compare-key="nav-3-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </bs-navbar>

      <!-- 4. Expand at md -->
      <bs-navbar expand="md" theme="dark" background="dark" container="fluid" aria-label="Fourth navbar example" data-compare-key="nav-4">
        <a class="navbar-brand" href="#">Expand at md</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-4-collapse" aria-controls="nav-4-collapse" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav-4-collapse">
          <bs-nav class="me-auto mb-2 mb-md-0" data-compare-key="nav-4-nav">
            <bs-nav-item href="#" active>Home</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
            <bs-nav-item disabled>Disabled</bs-nav-item>
          </bs-nav>
          <form role="search" data-compare-key="nav-4-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </bs-navbar>

      <!-- 5. Expand at lg -->
      <bs-navbar expand="lg" theme="dark" background="dark" container="fluid" aria-label="Fifth navbar example" data-compare-key="nav-5">
        <a class="navbar-brand" href="#">Expand at lg</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-5-collapse" aria-controls="nav-5-collapse" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav-5-collapse">
          <bs-nav class="me-auto mb-2 mb-lg-0" data-compare-key="nav-5-nav">
            <bs-nav-item href="#" active>Home</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
            <bs-nav-item disabled>Disabled</bs-nav-item>
          </bs-nav>
          <form role="search" data-compare-key="nav-5-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </bs-navbar>

      <!-- 6. Expand at xl -->
      <bs-navbar expand="xl" theme="dark" background="dark" container="fluid" aria-label="Sixth navbar example" data-compare-key="nav-6">
        <a class="navbar-brand" href="#">Expand at xl</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-6-collapse" aria-controls="nav-6-collapse" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav-6-collapse">
          <bs-nav class="me-auto mb-2 mb-xl-0" data-compare-key="nav-6-nav">
            <bs-nav-item href="#" active>Home</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
            <bs-nav-item disabled>Disabled</bs-nav-item>
          </bs-nav>
          <form role="search" data-compare-key="nav-6-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </bs-navbar>

      <!-- 7. Expand at xxl -->
      <bs-navbar expand="xxl" theme="dark" background="dark" container="fluid" aria-label="Seventh navbar example" data-compare-key="nav-7">
        <a class="navbar-brand" href="#">Expand at xxl</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-7-collapse" aria-controls="nav-7-collapse" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav-7-collapse">
          <bs-nav class="me-auto mb-2 mb-xl-0" data-compare-key="nav-7-nav">
            <bs-nav-item href="#" active>Home</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
            <bs-nav-item disabled>Disabled</bs-nav-item>
          </bs-nav>
          <form role="search" data-compare-key="nav-7-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </bs-navbar>

      <!-- 8. Container (responsive) -->
      <bs-navbar expand="lg" theme="dark" background="dark" container="default" aria-label="Eighth navbar example" data-compare-key="nav-8">
        <a class="navbar-brand" href="#">Container</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-8-collapse" aria-controls="nav-8-collapse" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav-8-collapse">
          <bs-nav class="me-auto mb-2 mb-lg-0" data-compare-key="nav-8-nav">
            <bs-nav-item href="#" active>Home</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
          </bs-nav>
          <form role="search" data-compare-key="nav-8-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </bs-navbar>

      <!-- 9. Container XL -->
      <bs-navbar expand="lg" theme="dark" background="dark" container="xl" aria-label="Ninth navbar example" data-compare-key="nav-9">
        <a class="navbar-brand" href="#">Container XL</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-9-collapse" aria-controls="nav-9-collapse" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav-9-collapse">
          <bs-nav class="me-auto mb-2 mb-lg-0" data-compare-key="nav-9-nav">
            <bs-nav-item href="#" active>Home</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
          </bs-nav>
          <form role="search" data-compare-key="nav-9-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </bs-navbar>

      <div class="container-xl mb-4" data-compare-key="container-xl-note">
        <p>Matching .container-xl...</p>
      </div>

      <!-- 10. Centered nav only (dark) -->
      <bs-navbar expand="lg" theme="dark" background="dark" container="fluid" aria-label="Tenth navbar example" data-compare-key="nav-10">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-10-collapse" aria-controls="nav-10-collapse" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-md-center" id="nav-10-collapse">
          <bs-nav>
            <bs-nav-item href="#" active>Centered nav only</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
            <bs-nav-item href="#">Link</bs-nav-item>
          </bs-nav>
        </div>
      </bs-navbar>

      <!-- 11-13 wrapped in a .container -->
      <div class="container">
        <!-- 11. Light tertiary in container -->
        <bs-navbar expand="lg" background="body-tertiary" container="fluid" class="rounded" aria-label="Eleventh navbar example" data-compare-key="nav-11">
          <a class="navbar-brand" href="#">Navbar</a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-11-collapse" aria-controls="nav-11-collapse" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="nav-11-collapse">
            <bs-nav class="me-auto mb-2 mb-lg-0" data-compare-key="nav-11-nav">
              <bs-nav-item href="#" active>Home</bs-nav-item>
              <bs-nav-item href="#">Link</bs-nav-item>
            </bs-nav>
            <form role="search" data-compare-key="nav-11-form">
              <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
            </form>
          </div>
        </bs-navbar>

        <!-- 12. Centered nav only (light) -->
        <bs-navbar expand="lg" background="body-tertiary" container="fluid" class="rounded mt-3" aria-label="Twelfth navbar example" data-compare-key="nav-12">
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-12-collapse" aria-controls="nav-12-collapse" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse justify-content-md-center" id="nav-12-collapse">
            <bs-nav>
              <bs-nav-item href="#" active>Centered nav only</bs-nav-item>
              <bs-nav-item href="#">Link</bs-nav-item>
              <bs-nav-item href="#">Link</bs-nav-item>
            </bs-nav>
          </div>
        </bs-navbar>

        <!-- 13. Centered nav with brand split -->
        <bs-navbar expand="lg" background="body-tertiary" container="fluid" class="rounded mt-3" aria-label="Thirteenth navbar example" data-compare-key="nav-13">
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-13-collapse" aria-controls="nav-13-collapse" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse d-lg-flex" id="nav-13-collapse">
            <a class="navbar-brand col-lg-3 me-0" href="#">Centered nav</a>
            <bs-nav class="col-lg-6 justify-content-lg-center" data-compare-key="nav-13-nav">
              <bs-nav-item href="#" active>Home</bs-nav-item>
              <bs-nav-item href="#">Link</bs-nav-item>
            </bs-nav>
            <bs-nav class="col-lg-3 justify-content-lg-end" data-compare-key="nav-13-nav-right">
              <bs-nav-item href="#">Sign up</bs-nav-item>
            </bs-nav>
          </div>
        </bs-navbar>
      </div>

      <div class="container my-5" data-compare-key="hero-wrap">
        <div class="bg-body-tertiary p-5 rounded" data-compare-key="hero">
          <div class="col-sm-8 mx-auto" data-compare-key="hero-inner">
            <h1 data-compare-key="hero-title">Navbar examples</h1>
            <p data-compare-key="hero-lead-1">This example is a quick exercise to illustrate how the navbar and its contents work. Some navbars extend the width of the viewport, others are confined within a <code>.container</code>. For positioning of navbars, checkout the <a href="#">top</a> and <a href="#">fixed top</a> examples.</p>
            <p data-compare-key="hero-lead-2">At the smallest breakpoint, the collapse plugin is used to hide the links and show a menu button to toggle the collapsed content.</p>
            <p data-compare-key="hero-cta-wrap">
              <bs-button variant="primary" href="/components/navbar/" data-compare-key="hero-cta">View navbar docs &raquo;</bs-button>
            </p>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
