---
// Plain Bootstrap reference for the Navbars example template.
// Mirrors https://getbootstrap.com/docs/5.3/examples/navbars/. Trimmed to
// the desktop-rendered variants so the comparator can run without the
// collapse / dropdown JS plugins.
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Navbars reference</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
    </style>
  </head>
  <body data-compare-key="root">
    <main>
      <nav class="navbar navbar-expand navbar-dark bg-dark" aria-label="Always expand" data-compare-key="nav-always">
        <div class="container-fluid">
          <a class="navbar-brand" href="#" data-compare-key="nav-always-brand">Always expand</a>
          <ul class="navbar-nav me-auto" data-compare-key="nav-always-nav">
            <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
          </ul>
          <form role="search" data-compare-key="nav-always-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </nav>

      <nav class="navbar navbar-expand-sm navbar-dark bg-dark" aria-label="Expand at sm" data-compare-key="nav-sm">
        <div class="container-fluid">
          <a class="navbar-brand" href="#" data-compare-key="nav-sm-brand">Expand at sm</a>
          <ul class="navbar-nav me-auto mb-2 mb-sm-0" data-compare-key="nav-sm-nav">
            <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
            <li class="nav-item"><a class="nav-link disabled" aria-disabled="true">Disabled</a></li>
          </ul>
          <form role="search" data-compare-key="nav-sm-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </nav>

      <nav class="navbar navbar-expand-md navbar-dark bg-dark" aria-label="Expand at md" data-compare-key="nav-md">
        <div class="container-fluid">
          <a class="navbar-brand" href="#" data-compare-key="nav-md-brand">Expand at md</a>
          <ul class="navbar-nav me-auto mb-2 mb-md-0" data-compare-key="nav-md-nav">
            <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
            <li class="nav-item"><a class="nav-link disabled" aria-disabled="true">Disabled</a></li>
          </ul>
          <form role="search" data-compare-key="nav-md-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </nav>

      <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Expand at lg" data-compare-key="nav-lg">
        <div class="container-fluid">
          <a class="navbar-brand" href="#" data-compare-key="nav-lg-brand">Expand at lg</a>
          <ul class="navbar-nav me-auto mb-2 mb-lg-0" data-compare-key="nav-lg-nav">
            <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
            <li class="nav-item"><a class="nav-link disabled" aria-disabled="true">Disabled</a></li>
          </ul>
          <form role="search" data-compare-key="nav-lg-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </nav>

      <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Container" data-compare-key="nav-container">
        <div class="container">
          <a class="navbar-brand" href="#" data-compare-key="nav-container-brand">Container</a>
          <ul class="navbar-nav me-auto mb-2 mb-lg-0" data-compare-key="nav-container-nav">
            <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
          </ul>
          <form role="search" data-compare-key="nav-container-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </nav>

      <div class="container">
        <nav class="navbar navbar-expand-lg bg-body-tertiary rounded mt-3" aria-label="Light tertiary" data-compare-key="nav-tertiary">
          <div class="container-fluid">
            <a class="navbar-brand" href="#" data-compare-key="nav-tertiary-brand">Navbar</a>
            <ul class="navbar-nav me-auto mb-2 mb-lg-0" data-compare-key="nav-tertiary-nav">
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
            </ul>
            <form role="search" data-compare-key="nav-tertiary-form">
              <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
            </form>
          </div>
        </nav>
      </div>
    </main>
  </body>
</html>
