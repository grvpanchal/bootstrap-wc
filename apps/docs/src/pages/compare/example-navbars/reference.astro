          <div class="collapse navbar-collapse" data-compare-key="nav-5-collapse">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0" data-compare-key="nav-5-nav">
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
              <li class="nav-item"><a class="nav-link disabled" aria-disabled="true">Disabled</a></li>
            </ul>
            <form role="search" data-compare-key="nav-5-form">
              <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
            </form>
          </div>
        </div>
      </nav>

      <!-- 6. Expand at xl -->
      <nav class="navbar navbar-expand-xl navbar-dark bg-dark" aria-label="Sixth navbar example" data-compare-key="nav-6">
        <div class="container-fluid">
          <a class="navbar-brand" href="#" data-compare-key="nav-6-brand">Expand at xl</a>
          <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-6-toggler">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" data-compare-key="nav-6-collapse">
            <ul class="navbar-nav me-auto mb-2 mb-xl-0" data-compare-key="nav-6-nav">
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
              <li class="nav-item"><a class="nav-link disabled" aria-disabled="true">Disabled</a></li>
            </ul>
            <form role="search" data-compare-key="nav-6-form">
              <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
