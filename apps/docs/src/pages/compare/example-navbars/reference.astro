        </div>
      </nav>

      <!-- 7. Expand at xxl -->
      <nav class="navbar navbar-expand-xxl navbar-dark bg-dark" aria-label="Seventh navbar example" data-compare-key="nav-7">
        <div class="container-fluid">
          <a class="navbar-brand" href="#" data-compare-key="nav-7-brand">Expand at xxl</a>
          <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-7-toggler">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" data-compare-key="nav-7-collapse">
            <ul class="navbar-nav me-auto mb-2 mb-xl-0" data-compare-key="nav-7-nav">
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
              <li class="nav-item"><a class="nav-link disabled" aria-disabled="true">Disabled</a></li>
            </ul>
            <form role="search" data-compare-key="nav-7-form">
              <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
            </form>
          </div>
        </div>
      </nav>

      <!-- 8. Container -->
      <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Eighth navbar example" data-compare-key="nav-8">
        <div class="container">
          <a class="navbar-brand" href="#" data-compare-key="nav-8-brand">Container</a>
          <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-8-toggler">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" data-compare-key="nav-8-collapse">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0" data-compare-key="nav-8-nav">
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
            </ul>
            <form role="search" data-compare-key="nav-8-form">
              <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
            </form>
          </div>
        </div>
      </nav>

      <!-- 9. Container XL -->
      <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Ninth navbar example" data-compare-key="nav-9">
        <div class="container-xl">
          <a class="navbar-brand" href="#" data-compare-key="nav-9-brand">Container XL</a>
          <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-9-toggler">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" data-compare-key="nav-9-collapse">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0" data-compare-key="nav-9-nav">
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
            </ul>
            <form role="search" data-compare-key="nav-9-form">
              <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
            </form>
          </div>
        </div>
      </nav>

      <div class="container-xl mb-4" data-compare-key="container-xl-note">
        <p>Matching .container-xl...</p>
      </div>

      <!-- 10. Centered nav only (dark) -->
      <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Tenth navbar example" data-compare-key="nav-10">
        <div class="container-fluid">
          <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-10-toggler">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse justify-content-md-center" data-compare-key="nav-10-collapse">
            <ul class="navbar-nav" data-compare-key="nav-10-nav">
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Centered nav only</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
            </ul>
          </div>
        </div>
      </nav>

      <!-- 11. Light tertiary in container -->
      <div class="container">
        <nav class="navbar navbar-expand-lg bg-body-tertiary rounded" aria-label="Eleventh navbar example" data-compare-key="nav-11">
          <div class="container-fluid">
            <a class="navbar-brand" href="#" data-compare-key="nav-11-brand">Navbar</a>
            <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-11-toggler">
              <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" data-compare-key="nav-11-collapse">
              <ul class="navbar-nav me-auto mb-2 mb-lg-0" data-compare-key="nav-11-nav">
                <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
              </ul>
              <form role="search" data-compare-key="nav-11-form">
                <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
              </form>
            </div>
          </div>
        </nav>

        <!-- 12. Centered nav only (light) -->
        <nav class="navbar navbar-expand-lg bg-body-tertiary rounded mt-3" aria-label="Twelfth navbar example" data-compare-key="nav-12">
          <div class="container-fluid">
            <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-12-toggler">
              <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-md-center" data-compare-key="nav-12-collapse">
              <ul class="navbar-nav" data-compare-key="nav-12-nav">
                <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Centered nav only</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
              </ul>
            </div>
          </div>
        </nav>

        <!-- 13. Centered nav with brand split -->
        <nav class="navbar navbar-expand-lg bg-body-tertiary rounded mt-3" aria-label="Thirteenth navbar example" data-compare-key="nav-13">
          <div class="container-fluid">
            <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-13-toggler">
              <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-lg-flex" data-compare-key="nav-13-collapse">
              <a class="navbar-brand col-lg-3 me-0" href="#" data-compare-key="nav-13-brand">Centered nav</a>
              <ul class="navbar-nav col-lg-6 justify-content-lg-center" data-compare-key="nav-13-nav">
                <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
              </ul>
              <ul class="nav col-lg-3 justify-content-lg-end" data-compare-key="nav-13-nav-right">
                <li class="nav-item"><a class="nav-link" href="#">Sign up</a></li>
