---
// Plain Bootstrap reference for the Navbars example template.
// Mirrors https://getbootstrap.com/docs/5.3/examples/navbars/. Includes
// the toggler buttons / collapse markup so vertical heights match upstream
// (Bootstrap collapse JS is not loaded here — togglers visually mirror the
// reference but don't actually fold).
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Navbars reference</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
        padding-bottom: 20px;
      }
      .navbar {
        margin-bottom: 20px;
      }
    </style>
  </head>
  <body data-compare-key="root">
    <main>
      <!-- 1. Never expand (always collapsed) -->
      <nav class="navbar navbar-dark bg-dark" aria-label="First navbar example" data-compare-key="nav-1">
        <div class="container-fluid">
          <a class="navbar-brand" href="#" data-compare-key="nav-1-brand">Never expand</a>
          <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-1-toggler">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" data-compare-key="nav-1-collapse">
            <ul class="navbar-nav me-auto mb-2" data-compare-key="nav-1-nav">
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
              <li class="nav-item"><a class="nav-link disabled" aria-disabled="true">Disabled</a></li>
            </ul>
            <form class="d-flex" role="search" data-compare-key="nav-1-form">
              <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
              <button class="btn btn-outline-success" type="submit" data-compare-key="nav-1-submit">Search</button>
            </form>
          </div>
        </div>
      </nav>

      <!-- 2. Always expand -->
      <nav class="navbar navbar-expand navbar-dark bg-dark" aria-label="Second navbar example" data-compare-key="nav-2">
        <div class="container-fluid">
          <a class="navbar-brand" href="#" data-compare-key="nav-2-brand">Always expand</a>
          <ul class="navbar-nav me-auto" data-compare-key="nav-2-nav">
            <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
          </ul>
          <form role="search" data-compare-key="nav-2-form">
            <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
          </form>
        </div>
      </nav>

      <!-- 3. Expand at sm -->
      <nav class="navbar navbar-expand-sm navbar-dark bg-dark" aria-label="Third navbar example" data-compare-key="nav-3">
        <div class="container-fluid">
          <a class="navbar-brand" href="#" data-compare-key="nav-3-brand">Expand at sm</a>
          <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-3-toggler">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" data-compare-key="nav-3-collapse">
            <ul class="navbar-nav me-auto mb-2 mb-sm-0" data-compare-key="nav-3-nav">
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
              <li class="nav-item"><a class="nav-link disabled" aria-disabled="true">Disabled</a></li>
            </ul>
            <form role="search" data-compare-key="nav-3-form">
              <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
            </form>
          </div>
        </div>
      </nav>

      <!-- 4. Expand at md -->
      <nav class="navbar navbar-expand-md navbar-dark bg-dark" aria-label="Fourth navbar example" data-compare-key="nav-4">
        <div class="container-fluid">
          <a class="navbar-brand" href="#" data-compare-key="nav-4-brand">Expand at md</a>
          <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-4-toggler">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" data-compare-key="nav-4-collapse">
            <ul class="navbar-nav me-auto mb-2 mb-md-0" data-compare-key="nav-4-nav">
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="#">Home</a></li>
              <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
              <li class="nav-item"><a class="nav-link disabled" aria-disabled="true">Disabled</a></li>
            </ul>
            <form role="search" data-compare-key="nav-4-form">
              <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
            </form>
          </div>
        </div>
      </nav>

      <!-- 5. Expand at lg -->
      <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Fifth navbar example" data-compare-key="nav-5">
        <div class="container-fluid">
          <a class="navbar-brand" href="#" data-compare-key="nav-5-brand">Expand at lg</a>
          <button class="navbar-toggler" type="button" aria-label="Toggle navigation" data-compare-key="nav-5-toggler">
            <span class="navbar-toggler-icon"></span>
