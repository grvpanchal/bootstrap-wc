---
// Plain Bootstrap reference for the List Groups snippets page.
// Mirrors three representative variants from
// https://getbootstrap.com/docs/5.3/examples/list-groups/.
---

<!doctype html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>List groups reference</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .b-example-divider {
        width: 100%;
        height: 3rem;
        background-color: rgba(0, 0, 0, 0.1);
        border: solid rgba(0, 0, 0, 0.15);
        border-width: 1px 0;
        box-shadow:
          inset 0 0.5em 1.5em rgba(0, 0, 0, 0.1),
          inset 0 0.125em 0.5em rgba(0, 0, 0, 0.15);
      }
      .list-group-checkable .list-group-item {
        cursor: pointer;
        border-radius: 0.5rem;
      }
      .list-group-item-check {
        position: absolute;
        clip: rect(0, 0, 0, 0);
        pointer-events: none;
      }
      .list-group-item-check:hover + .list-group-item {
        background-color: var(--bs-secondary-bg);
      }
      .list-group-item-check:checked + .list-group-item {
        background-color: var(--bs-primary);
        color: var(--bs-white);
      }
      .list-group-radio .list-group-item {
        cursor: pointer;
        border-radius: 0.5rem;
      }
      .list-group-radio .form-check-input {
        z-index: 2;
        margin-top: -0.5em;
      }
      .list-group-radio .list-group-item:hover,
      .list-group-radio .list-group-item:focus {
        background-color: var(--bs-secondary-bg);
      }
      .list-group-radio .form-check-input:checked + .list-group-item {
        background-color: var(--bs-body);
        border-color: var(--bs-primary);
        box-shadow: 0 0 0 2px var(--bs-primary);
      }
      .list-group-radio .form-check-input[disabled] + .list-group-item,
      .list-group-radio .form-check-input:disabled + .list-group-item {
        pointer-events: none;
        filter: none;
        opacity: 0.5;
      }
    </style>
  </head>
  <body data-compare-key="root">
    <div class="d-flex flex-column flex-md-row p-4 gap-4 py-md-5 align-items-center justify-content-center" data-compare-key="row-rich">
      <div class="list-group" data-compare-key="rich-group">
        <a href="#" class="list-group-item list-group-item-action d-flex gap-3 py-3" aria-current="true">
          <span class="rounded-circle flex-shrink-0 bg-primary" style="width:32px;height:32px"></span>
          <div class="d-flex gap-2 w-100 justify-content-between">
            <div>
              <h6 class="mb-0">List group item heading</h6>
              <p class="mb-0 opacity-75">Some placeholder content in a paragraph.</p>
            </div>
            <small class="opacity-50 text-nowrap">now</small>
          </div>
        </a>
        <a href="#" class="list-group-item list-group-item-action d-flex gap-3 py-3">
          <span class="rounded-circle flex-shrink-0 bg-primary" style="width:32px;height:32px"></span>
          <div class="d-flex gap-2 w-100 justify-content-between">
            <div>
              <h6 class="mb-0">Another title here</h6>
              <p class="mb-0 opacity-75">Some placeholder content in a paragraph that goes a little longer so it wraps to a new line.</p>
            </div>
            <small class="opacity-50 text-nowrap">3d</small>
          </div>
        </a>
        <a href="#" class="list-group-item list-group-item-action d-flex gap-3 py-3">
          <span class="rounded-circle flex-shrink-0 bg-primary" style="width:32px;height:32px"></span>
          <div class="d-flex gap-2 w-100 justify-content-between">
            <div>
              <h6 class="mb-0">Third heading</h6>
              <p class="mb-0 opacity-75">Some placeholder content in a paragraph.</p>
            </div>
            <small class="opacity-50 text-nowrap">1w</small>
          </div>
        </a>
      </div>
    </div>
    <div class="b-example-divider"></div>

    <div class="d-flex flex-column flex-md-row p-4 gap-4 py-md-5 align-items-center justify-content-center" data-compare-key="row-checkable">
      <div class="list-group list-group-checkable d-grid gap-2 border-0" data-compare-key="checkable-group">
        <input class="list-group-item-check" type="checkbox" name="listGroupCheckableRadios" value="" id="listGroupCheckableRadios1" checked />
        <label class="list-group-item rounded-3 py-3" for="listGroupCheckableRadios1">
          First checkbox
          <span class="d-block small opacity-50">With support text underneath to add more detail</span>
        </label>
        <input class="list-group-item-check" type="checkbox" name="listGroupCheckableRadios" value="" id="listGroupCheckableRadios2" />
        <label class="list-group-item rounded-3 py-3" for="listGroupCheckableRadios2">
          Second checkbox
          <span class="d-block small opacity-50">Some help text</span>
        </label>
      </div>
    </div>
    <div class="b-example-divider"></div>

    <div class="d-flex flex-column flex-md-row p-4 gap-4 py-md-5 align-items-center justify-content-center" data-compare-key="row-radio">
      <div class="list-group list-group-radio d-grid gap-2 border-0" data-compare-key="radio-group">
        <div class="position-relative">
          <input class="form-check-input position-absolute top-50 end-0 me-3 fs-5" type="radio" name="listGroupRadios" id="listGroupRadios1" value="" checked />
          <label class="list-group-item py-3 pe-5" for="listGroupRadios1">
            <strong class="fw-semibold">First radio</strong>
            <span class="d-block small opacity-75">Simple description</span>
          </label>
        </div>
        <div class="position-relative">
          <input class="form-check-input position-absolute top-50 end-0 me-3 fs-5" type="radio" name="listGroupRadios" id="listGroupRadios2" value="" />
          <label class="list-group-item py-3 pe-5" for="listGroupRadios2">
            <strong class="fw-semibold">Second radio</strong>
            <span class="d-block small opacity-75">Another description</span>
          </label>
        </div>
      </div>
    </div>
    <div class="b-example-divider"></div>
  </body>
</html>
