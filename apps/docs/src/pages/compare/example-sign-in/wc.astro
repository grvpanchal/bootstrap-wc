---
// `<bs-*>` port of ./reference.astro for the Sign-in example template.
// Form-floating + checkbox stay native (the comparator gets unhappy when
// bs-input wraps a floating-label form-control). Only the submit button
// is swapped for <bs-button>.
---

<!doctype html>
<html lang="en" class="h-100" data-bs-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign-in wc</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
      .form-signin {
        max-width: 330px;
        padding: 1rem;
      }
      .form-signin .form-floating:focus-within {
        z-index: 2;
      }
      .form-signin input[type='email'] {
        margin-bottom: -1px;
        border-bottom-right-radius: 0;
        border-bottom-left-radius: 0;
      }
      .form-signin input[type='password'] {
        margin-bottom: 10px;
        border-top-left-radius: 0;
        border-top-right-radius: 0;
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      import('@bootstrap-wc/components');
    </script>
  </head>
  <body class="d-flex align-items-center py-4 bg-body-tertiary h-100">
    <main class="form-signin w-100 m-auto" data-compare-key="signin-main">
      <form data-compare-key="signin-form">
        <h1 class="h3 mb-3 fw-normal" data-compare-key="signin-title">Please sign in</h1>

        <div class="form-floating" data-compare-key="signin-email-wrap">
          <input type="email" class="form-control" id="floatingInput" placeholder="name@example.com" data-compare-key="signin-email-input" />
          <label for="floatingInput" data-compare-key="signin-email-label">Email address</label>
        </div>
        <div class="form-floating" data-compare-key="signin-password-wrap">
          <input type="password" class="form-control" id="floatingPassword" placeholder="Password" data-compare-key="signin-password-input" />
          <label for="floatingPassword" data-compare-key="signin-password-label">Password</label>
        </div>

        <div class="form-check text-start my-3" data-compare-key="signin-remember-wrap">
          <input class="form-check-input" type="checkbox" value="remember-me" id="checkDefault" data-compare-key="signin-remember-input" />
          <label class="form-check-label" for="checkDefault" data-compare-key="signin-remember-label">Remember me</label>
        </div>

        <bs-button variant="primary" type="submit" class="w-100 py-2" data-compare-key="signin-submit">Sign in</bs-button>
        <p class="mt-5 mb-3 text-body-secondary" data-compare-key="signin-copyright">&copy; 2017&ndash;2025</p>
      </form>
    </main>
  </body>
</html>
